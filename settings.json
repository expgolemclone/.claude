{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Agent"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "model": "claude-opus-4-6",
  "effortLevel": "max",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/exp/.claude/hooks/inject-extension-rules-toml.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/exp/.claude/hooks/block-settings-json-direct-edit.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/exp/.claude/hooks/block-git-add-force-staging.py"
          },
          {
            "type": "command",
            "command": "python3 /home/exp/.claude/hooks/block-git-commit-prohibited-keywords.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/exp/.claude/hooks/block-non-python-hook-scripts.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/exp/.claude/hooks/post-nixos-rebuild-verify-result.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/exp/.claude/hooks/stop-require-git-commit-and-push.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 /home/exp/.claude/hooks/stop-nixos-rebuild-on-config-change.py",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "python3 /home/exp/.claude/hooks/stop-suggest-open-github-issues.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 /home/exp/.claude/hooks/stop-require-source-verification.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
