{
  "permissions": {
    "deny": [
      "Task"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/0000250059/.claude/hooks/inject-rules.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/Users/0000250059/.claude/hooks/reload-ahk.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\0000250059\\.claude\\scripts\\notify-complete.ps1\""
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
