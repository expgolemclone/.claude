{
  "permissions": {
    "deny": [
      "Agent"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/inject-extension-rules-toml.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/block-settings-json-direct-edit.py"
          },
          {
            "type": "command",
            "command": "python3 hooks/block-protected-nix-config.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/block-git-add-force-staging.py"
          },
          {
            "type": "command",
            "command": "python3 hooks/block-git-commit-prohibited-keywords.py"
          },
          {
            "type": "command",
            "command": "python3 hooks/block-git-commit-protected-changes.py"
          },
          {
            "type": "command",
            "command": "python3 hooks/block-nixos-rebuild-protected-changes.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/post-verify-protected-nix-config.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/block-non-python-hook-scripts.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/stop-require-git-commit-and-push.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 hooks/stop-nixos-rebuild-on-config-change.py",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "python3 hooks/stop-require-source-verification.py",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
