------------------------------------------\n#define\t \tGROBAL_DEF\n#include\t\"sysdef.h\"\n#include\t<winioctl.h>\n#include\t<stdio.h>\n#include\t<fcntl.h>\n#include\t<errno.h>\n#include\t<string.h>\n\n#ifdef DBG\n#define D( x )  x\n#else\n#define D( x )\n#endif\n\n#define DP1_  if ((AU_task[TN_MO11RV].dbg_i & 0x0001) != 0) (void)printf\n#define DP2_  if ((AU_task[TN_MO11RV].dbg_i & 0x0002) != 0) (void)printf\n#define DP4_  if ((AU_task[TN_MO11RV].dbg_i & 0x0004) != 0) (void)printf\n#define DP8_  if ((AU_task[TN_MO11RV].dbg_i & 0x0008) != 0) (void)printf\n\n//------------------------------------------------------------------------------\n//\tプロセス内シンボル\n//------------------------------------------------------------------------------\n#define S_TAG\t\t0x80\t\t\t\t\t\t//コマンド タグ情報\n#define S_MAN\t\t0x82\t\t\t\t\t\t//コマンド マンマシン情報\n#define S_PAR\t\t4\t\t\t\t\t\t\t//ファンクションＭＰＢ部分情報\n#define S_ALL\t\t6\t\t\t\t\t\t\t//ファンクションＭＰＢ全情報\n#define S_ADC\t\t0\t\t\t\t\t\t\t//ファンクション ＡＤＣ用\n#define S_HSZ\t\t32\t\t\t\t\t\t\t//伝送ヘッダ byte size\n#define S_PSZ\t\t64\t\t\t\t\t\t\t//１部分情報データbyte size\n#define S_ASZ\t\t260\t\t\t\t\t\t\t//１全情報データbyte size\n#define S_MSZ\t\t16\t\t\t\t\t\t\t//マンマシンヘッダ byte size\n\n//------------------------------------------------------------------------------\n//\t関数プロトタイプ宣言部\n//------------------------------------------------------------------------------\nint\t\tf_11rv100();\t\t\t\t\t\t\t//１：１伝送受信初期処理\nvoid\tf_11rv200( union U_ONE_BUF* );\t\t\t//ＭＰＢ部分データ受信時処理\nBOOL\tf_11rv210( short*, short*, short* );\t//ＭＰＢ部分情報受信データ正当性判定処理\nvoid\tf_11rv300( union U_ONE_BUF* );\t\t\t//ＭＰＢ全データ受信時処理\nBOOL\tf_11rv310( short*, short*, short* );\t//ＭＰＢ全情報受信データ正当性判定処理\nvoid\tf_11rv400( union U_ONE_BUF* );\t\t\t//マンマシンコマンドデータ受信時処理\n\n\n//------------------------------------------------------------------------------\n//\tプロセス内コモンエリア\n//------------------------------------------------------------------------------\nHANDLE\t\t\t\t\t\tz_hAda;\t\t\t\t//ＡＤＡデバイスハンドル\nstruct ada4k_transferEx*\tz_pOne;\t\t\t\t//１：１伝送受信バッファポインタ\nstruct Q_T_GPCSM_MAN        z_cmdAns;\t        //マンマシン応答通知送信バッファ\n\n//------------------------------------------------------------------------------\n//\tメイン処理\n//------------------------------------------------------------------------------\nvoid main()\n{\n\tint\t\t\t\t\tRsts_i;\t\t\t\t\t//リターンステータス\n\tunsigned int\t\tbp_ui;\t\t\t\t\t//受信バッファポイント格納\n\tDWORD\t\t\t\tdwBufSize;\t\t\t\t//Ｒ／Ｗバッファサイズ\n\tDWORD\t\t\t\tdwRcvSize;\t\t\t\t//出力の実際のバイト数\n\tDWORD\t\t\t\tdwErrNo;\t\t\t\t//\n\tunion U_ONE_BUF*\tpOneBuf;\t\t\t\t//１：１受信データバッファポインタ\n\n\t//--------------------------------------------------------------------------\n\t//１：１伝送受信初期化処理を実施、失敗時はプロセス停止\n\t//--------------------------------------------------------------------------\n\tRsts_i = f_11rv100();\n\tif (0 != Rsts_i) exit(0);\n\n\t//--------------------------------------------------------------------------\n\t//以下を永久ループで１：１伝送受信で受信したデータに対応した処理を実施\n\t//--------------------------------------------------------------------------\n\twhile (TRUE) {\n\n\t\t//自ノード異常の間はここでループ\n\t\twhile (MU_pnet->mod_ui == MU_PNET_PERR_P) {\n\t\t\tD( DP2_(\"MO11RD 自ノード異常中により睡眠中\\n\"); )\n\t\t\t(void)Sleep(MF_pnet->wait_ui*1000);\t\t\t//指定時間中断\n\t\t}\n\n\t\t//受信バッファはトレース中\n\t\tif (MU_pnet->opnt_ui <= (CNF_TRBUF_N-2)) {\n\t\t\t++MU_pnet->opnt_ui;\t\t\t\t\t\t//次の受信バッファを指定\n\t\t}\t\t\t\t\t\t\t\t\t\t\t//受信バッファはトレース開始\n\t\telse if(MU_pnet->opnt_ui != (CNF_TRBUF_N-1)) {\n\t\t\tMU_pnet->opnt_ui = 0;\t\t\t\t\t//  トレース先頭バッファを指定\n\t\t}\t\t\t\t\t\t\t\t\t\t\t//上記以外は最終面\n\n\t\tbp_ui = MU_pnet->opnt_ui;\t\t\t\t\t//受信バッファポイントセット\n\n\t\t//受信バッファセット\n\t\tz_pOne = &MU_pnet->obf[bp_ui];\n\n\t\t//----------------------------------------------------------------------\n\t\t//１：１伝送データ受信待ち\n\t\t//\tなんらかのデータを受信するまでこのライブラリ内で待ち状態になります。\n\t\t//----------------------------------------------------------------------\n\t\tdwBufSize = sizeof(struct ada4k_transferEx);\n\t\tdwRcvSize = 0;\n\t\tRsts_i = DeviceIoControl( z_hAda, IOCTL_ADA4K_RECEIVE, z_pOne, dwBufSize,\n\t\t\t\t\t\t\t\t  z_pOne, dwBufSize, &dwRcvSize, NULL );\n\t\tif (0 == Rsts_i) {\n\n\t\t\tdwErrNo = GetLastError();\n\n\t\t\t//エラーログ登録\n\t\t\tF_errlog(0x0150, 0x0001, dwErrNo, 0, 0, 0, \"１：１受信エラー(INF1:err)\");\n\n\t\t\t//自ノード異常\n\t\t\tif ((ERROR_NETWORK_ACCESS_DENIED == dwErrNo) ||\t//Ｆ／Ｗが動作していません もしくは\n\t\t\t\t(ERROR_NOT_READY             == dwErrNo)) {\t//実行不能です\n\n\t\t\t\t//データ上では正常(初回の異常検地の場合)\n\t\t\t\tif (MU_pnet->mod_ui == MU_PNET_PNOR_P) {\n\t\t\t\t\t//入出力監視へP-NET初期化要求を実施（メモリ要求）\n\t\t\t\t\t//\tP-NET(ADA)運用データの要求マスク情報にP-NET初期化要求ビット(要因:ノード異常)を設定\n\t\t\t\t\tMU_pnet->reqflg_ui[MU_PNET_INI_P] = SS_ON_P;\n\t\t\t\t}\n\t\t\t\t(void)Sleep(MF_pnet->wait_ui*1000);\t\t\t//指定時間中断\n\t\t\t\tcontinue;\t\t\t\t\t\t\t\t\t//永久繰り返し処理へ\n\t\t\t}\n\t\t\t//Ｉ／Ｏタイムアウト\n\t\t\telse if (ERROR_SEM_TIMEOUT == dwErrNo) {\n\t\t\t\tcontinue;\t\t\t\t\t\t\t\t\t//永久繰り返し処理へ\n\t\t\t}\n\t\t\t//待ち中にADA初期化された時に発生するエラーコード\n\t\t\telse if (ERROR_OPERATION_ABORTED == dwErrNo) {\n\t\t\t\tcontinue;\t\t\t\t\t\t\t\t\t//永久繰り返し処理へ\n\t\t\t}\n\t\t\t//上記以外（システム異常）\n\t\t\telse {\n\t\t\t\tRsts_i = CloseHandle(z_hAda);\t\t\t\t//P-NETをクローズする\n\t\t\t\texit(0);\t\t\t\t\t\t\t\t\t//プロセス終了\n\t\t\t}\n\t\t}\n\n\t\t//Ｆ／Ｗステータスが正常値以外の場合\tYS080617\n\t\tif (0x0001 != z_pOne->transfer.fwstatus) {\n\t\t\tF_errlog( 0x0150, 0x0007, z_pOne->transfer.fwstatus, 0, 0, 0,\n\t\t\t\t  \"Ｆ／Ｗステータス異常(INF1:FwSts)\" );\n\t\t\t//ログ記録は行うが、従来この処理ではＦＷステータスチェックはしていないため\n\t\t\t//\t処理はとりあえずこのまま継続させる。\n\t\t}\n\n        //自装置回線種別がADA4000無効なら\n        if (!(JD_wstn[AF_sys->ownn_s - 1].pnetknd_us & PNET_KIND_ADA4_N))\n            continue;                                       //永久繰り返し処理へ\n\n\t\t//ステーション番号逸脱\n\t\tif ((z_pOne->transfer.nodenum < 1) || (z_pOne->transfer.nodenum > CNF_MAX_ADAPCS_N)) {\n\t\t\tF_errlog( 0x1000, 0x0003, z_pOne->transfer.nodenum, 0, 0, 0,\n\t\t\t\t\t  \"受信ステーション番号不正(INF1:Node)\" );\n\t\t\tcontinue;\t\t\t\t\t\t\t\t\t\t//永久繰り返し処理へ\n\t\t}\n\n\t\t//ステーション未接続\n\t\tif (SS_ENTRY_P != JD_loc[z_pOne->transfer.nodenum-1].inf_us) {\n\t\t\tF_errlog( 0x1000, 0x0004, z_pOne->transfer.nodenum, 0, 0, 0,\n\t\t\t\t\t  \"ステーション未実装(INF1:Node)\" );\n\t\t\tcontinue;\t\t\t\t\t\t\t\t\t\t//永久繰り返し処理へ\n\t\t}\n\n\t\t//ステーション伝送不可能 もしくは 監視不可能\n\t\tif ((MU_stn[z_pOne->transfer.nodenum].mod_ui == MU_STN_OLD_P) ||\n\t\t\t(MU_stn[z_pOne->transfer.nodenum].mod_ui == MU_STN_DOWN_P)) {\n\t\t\tcontinue;\t\t\t\t\t\t\t\t\t\t//永久繰り返し処理へ\n\t\t}\n\n\t\t//データ受信サイズ不正\n\t\tif ((z_pOne->transfer.datalen < 2) || (z_pOne->transfer.datalen > 4096)) {\n\t\t\tF_errlog( 0x1000, 0x0005, z_pOne->transfer.nodenum, z_pOne->transfer.datalen, 0, 0,\n\t\t\t\t\t  \"受信データサイズ不正(INF1:Node,INF2:Size)\" );\n\t\t\tcontinue;\t\t\t\t\t\t\t\t\t\t//永久繰り返し処理へ\n\t\t}\n\n        //自装置動作モードがマスタ(等価中)，サブ，試験以外の場合は次処理へcontinue\n        if ((AU_MAS_P != AU_sys->smod_s) && \n            (AU_MASE_P != AU_sys->smod_s) &&\n            (AU_SUB_P != AU_sys->smod_s) &&\n            (AU_TST_P != AU_sys->smod_s)) continue;\n\n\t\t//----------------------------------------------------------------------\n\t\t//\t受信コマンドに対応した処理を実施\n\t\t//----------------------------------------------------------------------\n\t\tpOneBuf = (union U_ONE_BUF*)&z_pOne->buf[0];\n\n\t\t//ＭＰＢ部分データ受信\t------------------------------------------------\n\t\tif ((pOneBuf->ohd.com_uc == S_TAG) &&\n\t\t\t(pOneBuf->ohd.fnc_uc == S_PAR)){\n\t\t\t//ＭＰＢ部分データ受信時処理\n\t\t\tf_11rv200( pOneBuf );\n\t\t}\n\t\telse if ((pOneBuf->ohd.com_uc == S_TAG ) &&\n\t\t\t\t (pOneBuf->ohd.fnc_uc == 0x0084)) {\n\t\t\t//相手先ＰＣＳが停止モード等の時にＭＰＢ部分情報要求を実施すると\n\t\t\t//　この応答コードで戻るようです。このパターンは簡単に起こせるものであり\n\t\t\t//\tこの状態の時にエラーログを記録するのも無駄なので排除します。\n\t\t}\n\t\t//ＭＰＢ全データ処理\t------------------------------------------------\n\t\telse if((pOneBuf->ohd.com_uc == S_TAG) &&\n\t\t\t\t  (pOneBuf->ohd.fnc_uc == S_ALL)) {\n\t\t\t//ＭＰＢ全データ受信時処理\n\t\t\tf_11rv300( pOneBuf );\n\t\t}\n\t\t//マンマシン データ処理\t------------------------------------------------\n\t\telse if((pOneBuf->mhd.com_uc == S_MAN) &&\n\t\t\t\t  (pOneBuf->mhd.fnc_uc == S_ADC)) {\n\t\t\t//マンマシンコマンド応答データ受信時処理\n\t\t\tf_11rv400( pOneBuf );\n\t\t}\n\t\t//未定義 データ処理\t----------------------------------------------------\n\t\telse {\n\t\t\tF_errlog( 0x1000, 0x0006, z_pOne->transfer.nodenum, pOneBuf->ohd.com_uc,\n\t\t\t\t\t  pOneBuf->ohd.fnc_uc, 0,\n\t\t\t\t\t  \"未定義データ受信(INF1:Node,INF2:CMD,INF3:FNC)\" );\n\t\t}\n\t}\n}\n\n//------------------------------------------------------------------------------\n//\t１：１伝送受信初期処理\n//------------------------------------------------------------------------------\nint\tf_11rv100()\n{\n\t//プロセス標準初期処理\n\tF_init(TN_MO11RV, 0, 0);\n\t\n\t\n\t//初期化中フラグを落とす\n\tAU_task[TN_MO11RV].prf_i &= (~AU_INIT_P);\n\t\n\t//自装置の回線種別がADA4000無効?\n    while (!(JD_wstn[AF_sys->ownn_s - 1].pnetknd_us & PNET_KIND_ADA4_N)) {\n\t   Sleep(1000);\n    }\n\n\n\t//P-NETをオープンする\n\tz_hAda = CreateFile( \"\\\\\\\\.\\\\ADA4K0\",\n\t\t\t\t\t\t GENERIC_READ | GENERIC_WRITE,\n\t\t\t\t\t\t FILE_SHARE_READ | FILE_SHARE_WRITE,\n\t\t\t\t\t\t NULL,\n\t\t\t\t\t\t OPEN_EXISTING,\n\t\t\t\t\t\t FILE_ATTRIBUTE_NORMAL,\n\t\t\t\t\t\t NULL );\n\tif (INVALID_HANDLE_VALUE == z_hAda) {\n\t\tF_errlog(0x0150, 0x1001, GetLastError(), 0, 0, 0, \"P-NET(ADA) OPEN ERR\");\n\t\treturn -1;\n\t}\n\treturn 0;\n}\n\n//------------------------------------------------------------------------------\n//ＭＰＢ部分データ受信時処理\n//------------------------------------------------------------------------------\nvoid f_11rv200(union U_ONE_BUF* pOneBuf)\n{\n\tBOOL\t\t\t\tbChgDat;\t\t//変更データフラグ(変更なし:FALSE/変更あり:TRUE)\n\tBOOL\t\t\t\tbRsts;\t\t\t//リターンステータス\n\tint\t\t\t\t\tRsts_i;\t\t\t//リターンステータス\n\tint\t\t\t\t\tSize_i;\t\t\t//サイズ\n\tint\t\t\t\t\ti, j;\t\t\t//カウンタ\n\tunsigned short\t\tTagNum_us;\t\t//タグ数\n\tshort\t\t\t\tSid_s;\t\t\t//ステーションＩＤ\n\tshort\t\t\t\tPid_s;\t\t\t//プロセスＩＤ\n\tstruct Q_T_HEAD\t\tqh;\t\t\t\t//ＱＵＥヘッダー\n\n\t//タグ数をタグ数格納エリアへ\n\tTagNum_us = pOneBuf->ohd.num_us ;\n\tif ((z_pOne->transfer.datalen - S_HSZ) / S_PSZ\t!= TagNum_us) {\t//受信データ数不正\n\t\tF_errlog( 0x1000, 0x2001, z_pOne->transfer.nodenum, z_pOne->transfer.datalen, TagNum_us, 0,\n\t\t\t\t  \"受信データ数不正(INF1:Node,INF2:Size,INF3:TagNum)\" );\n\t\treturn;\n\t}\n\n\t//受信データを対応するＭＰＢエリアへ展開する。\n\tbChgDat = FALSE;\n\tfor (i=0; i<TagNum_us; i++) {\n\n\t\t//タグ単位のデータ項目正当性判定処理を実施\n\t\tbRsts = f_11rv210( (short*)&pOneBuf->byte_uc[32+i*64], &Sid_s, &Pid_s );\n\t\tif (!bRsts) continue;\n\n\t\t//データ設定対照となるＭＰＢ部分情報の面を検索\n\t\t//\t１箇所とは限らないので最後までチェックする必要があります。\n\t\tfor (j=1; j<=CNF_MPB_PAR_N;j++) {\n\n\t\t\t//MPB部分情報要求運用データのSID,PIDが一致し、かつクリア指定値がＯＮで無い事\n\t\t\t//\tクリア指定値がＯＮの場合は未だ要求運用データの設定値を送信側が内部取込み\n\t\t\t//\tしていないのでこの段階では展開しない。\n\t\t\tif ((Sid_s == JU_plpmpbs[j].pmpb_s[0]) &&\n\t\t\t\t(Pid_s == JU_plpmpbs[j].pmpb_s[1]) ) {\n\t\t\t\tmemcpy((unsigned char *)&JU_plpmpb[j].pmpb_s[JU_MPB_ST_P],\n               (unsigned char *)&pOneBuf->byte_uc[32+i*64],\n\t\t       sizeof(struct T_JU_plpmpb)) ;\n\t\t\t\t\t\t\t\t\t\t\t\t  /*      PCS番号と           */\n\t\t\t\t\t\t\t\t\t\t\t\t  /*      計器番号をｾｯﾄ       */\n\t\t\t\tJU_plpmpb[j].pmpb_s[JU_MPB_ST_P] = Sid_s - 1;\n\t\t\t\tJU_plpmpb[j].pmpb_s[JU_MPB_ID_P] = Pid_s - 1;\n\t\t//                                                                            OPS5k▼\n\t\t        if ((j >= SYS_MPB_OFSET_P) &&             /*  任意用エリア内なら      */\n\t\t            (j <= SYS_MPB_OFSET_END_P))           /*  有効データフラグセット  */\n\t\t          JU_plpmpbs[j].sts_s |= JU_PLPMPBS_REPLY_P ;\n          \n\t\t\t\tbChgDat = TRUE;\n\t\t\t}\n\t\t}\n\t}\n\n\t//--------------------------------------------------------------------------\n\t//\t高速計測へデータ更新通知を送信\n\t//--------------------------------------------------------------------------\n\tif (bChgDat) {\n\t\tmemset( &qh, 0, sizeof(qh) );\n\t\tqh.func_s = QF_BMESH_CHG_P;\t\t\t//データ更新通知\n\t\tqh.sfnc_s = QL_BMESH_PART_P;\t\t//部分情報\n\t\tSize_i\t  = sizeof(qh);\n\t\tRsts_i = F_quemgr ( (int)QUE_ENQ_P | QUE_NOWAIT_P,\n\t\t                    (short)Q_BMESH_KEY1,\n\t\t                    &qh,\n\t\t                    &Size_i );\n\t\tif (RS_SUC != Rsts_i) {\n\t\t\tF_errlog( 0x0131, 0x2002, Rsts_i, 0, 0, 0,\n\t\t\t\t\t  \"データ変更通知(部分情報)失敗(INF1:Stat)\" );\n\t\t}\n\t}\n}\n\n//------------------------------------------------------------------------------\n//ＭＰＢ部分情報データ判定処理\n//------------------------------------------------------------------------------\nBOOL\tf_11rv210( short* pMpbp, short* pSid_s, short* pPid_s )\n{\n\tshort\t\t\tSid_s;\t\t\t\t//ステーションＩＤ\n\tshort\t\t\tPid_s;\t\t\t\t//物理ＩＤ\n\tshort\t\t\tPcsIdx_s;\t\t\t//PCSインデックス\n\n\tSid_s = pMpbp[JU_MPB_ST_P];\t\t\t//ステーションＩＤ\n\tPid_s = pMpbp[JU_MPB_ID_P];\t\t\t//計器分類＋物理ＩＤ\n\n\t//ステーションＩＤ範囲チェック\n\tif ((1 > Sid_s) || (CNF_MAX_ADAPCS_N < Sid_s)) return FALSE;\n\n\t//計器分類チェック（計装でない場合はエラー）\n\tif ((Pid_s & 0xF000) != 0x1000) return FALSE;\n\n\t//計器分類部を除外する。\n\tPid_s = (Pid_s & 0x0FFF) + 1;\n\n\tPcsIdx_s = Sid_s - 1;\n\n\t//ＰＣＳ実装チェック 未実装の場合はエラー\n\tif (SS_ENTRY_P != JD_loc[PcsIdx_s].inf_us)\t\treturn FALSE;\n\n\t//回線種別がADA4000でない場合はエラー\n\tif (JD_NET_ADA_P != JD_loc[PcsIdx_s].netknd_us)\treturn FALSE;\n\n    //ノード種別がVPCSの場合はエラー\n    if ((JD_STN_VPCS_P == JD_loc[PcsIdx_s].nodes_us) ||\n       (JD_STN_VPCS_2_P == JD_loc[PcsIdx_s].nodes_us)) return FALSE;\n\t\n\t//ＰＣＳ種別がサポート外の場合はエラー(ADC4000,ADC5000,VC5000, VC100)\n\tif ((JD_loc[PcsIdx_s].tyopcs_us != JD_A4K_P  ) &&\n\t\t(JD_loc[PcsIdx_s].tyopcs_us != JD_A5K_P  ) &&\n\t\t(JD_loc[PcsIdx_s].tyopcs_us != JD_RC5_P))\treturn FALSE;\n\n\t//最大物理ＩＤチック\n\tif (JD_loc[PcsIdx_s].skiki_us >= CNF_KEIKI_N) return FALSE;\n\n\t//物理ＩＤ範囲チェック\n\tif ((1 > Pid_s) || ((JD_loc[PcsIdx_s].skiki_us + 1) < Pid_s)) return FALSE;\n\n\t//下記の２つはやろうかとも思ったのですが、P-NET(Ethernet)側が\n\t//\tやってないようなのではずしています。\n\t\t//監視グループ外\n\t\t//ＰＣＳロック\n\n\t*pSid_s = Sid_s;\n\t*pPid_s = Pid_s;\n\n\treturn TRUE;\n}\n\n//------------------------------------------------------------------------------\n//ＭＰＢ全データ受信時処理\n//------------------------------------------------------------------------------\nvoid f_11rv300(union U_ONE_BUF* pOneBuf)\n{\n    int\t\t\tbChgDat;\t//変更データフラグ(変更なし:FALSE/変更あり:TRUE)\n    int\t\t\tbRsts;\t\t//リターンステータス\n    int\t\t\tRsts_i;\t\t//リターンステータス\n    int\t\t\tSize_i;     //サイズ\n    int\t\t\ti, j;\t\t//カウンタ\n    unsigned short\tTagNum_us;\t//タグ数\n    short\t\tSid_s;\t\t//ステーションＩＤ\n    short\t\tPid_s;\t\t//プロセスＩＤ\n    struct Q_T_HEAD\tqh;\t\t//ＱＵＥヘッダー\n\n    D( DP1_(\"MO11RV ＭＰＢ全データ受信\\n\"); )\n\n        //タグ数をタグ数格納エリアへ\n        TagNum_us = pOneBuf->ohd.num_us ;\n    if ((z_pOne->transfer.datalen - S_HSZ) / S_ASZ != TagNum_us) { //受信データ数不正\n\n        F_errlog( 0x1000, 0x3001, z_pOne->transfer.nodenum, z_pOne->transfer.datalen, TagNum_us, 0,\n            \"受信データ数不正(INF1:Node,INF2:Size,INF3:TagNum)\");\n        return;\n    }\n\n    //受信データを対応するＭＰＢエリアへ展開する。\n    bChgDat = SS_FALSE_P;\n    for (i=0; i<TagNum_us; i++) {\n\n        //タグ単位のデータ項目正当性判定処理を実施\n        bRsts = f_11rv310( (short*)&pOneBuf->byte_uc[S_HSZ+i*S_ASZ], &Sid_s, &Pid_s );\n        if (!bRsts) continue;\n\n        //データ設定対照となるＭＰＢ部分情報の面を検索\n        //  １箇所とは限らないので最後までチェックする必要があります。\n        for (j=1; j<=CNF_MPB_ALL_N;j++) {\n\n            //MPB全情報要求運用データのSID,PIDが一致し、かつクリア指定値がＯＮで無い事\n            //\tクリア指定値がＯＮの場合は未だ要求運用データの設定値を送信側が内部取込み\n            //\tしていないのでこの段階では展開しない。\n            if ((Sid_s == JU_plampbs[j].ampb_s[0]) &&\n                (Pid_s == JU_plampbs[j].ampb_s[1])) {\n                    memcpy((unsigned char *)&JU_plampb[j].ampb_s[0],\n                        (unsigned char *)&pOneBuf->byte_uc[S_HSZ+i*S_ASZ],\n                        S_ASZ ) ;\n                    JU_plampb[j].ampb_s[0] = Sid_s - 1;          /*      PCSﾌﾞﾛｯｸ番号ｾｯﾄ      */\n                    JU_plampb[j].ampb_s[1] = Pid_s - 1;          /*      換算後計器番号ｾｯﾄ    */\n\n                    bChgDat = SS_TRUE_P;\n            }\n        }\n    }\n\n    //--------------------------------------------------------------------------\n    //\t高速計測へデータ更新通知を送信\n    //--------------------------------------------------------------------------\n    if (bChgDat) {\n        memset( &qh, 0, sizeof(struct Q_T_HEAD) );\n        qh.func_s = QF_BMESH_CHG_P;\t//データ更新通知\n        qh.sfnc_s = QL_BMESH_ALL_P;\t//全情報\n        Size_i = sizeof(struct Q_T_HEAD);\n        Rsts_i = F_quemgr ( QUE_ENQ_P | QUE_NOWAIT_P,\n            (short)Q_BMESH_KEY1, &qh, &Size_i );\n        if (RS_SUC != Rsts_i) {\n            F_errlog( 0x0131, 0x3002, Rsts_i, 0, 0, 0,\n                \"データ変更通知(全情報)失敗(INF1:Stat)\");\n        }\n    }\n}\n\n//------------------------------------------------------------------------------\n//ＭＰＢ全情報データ判定処理\n//------------------------------------------------------------------------------\nint\tf_11rv310( short* pMpba, short* pSid_s, short* pPid_s )\n{\n    short\t    Sid_s;\t\t//ステーションＩＤ\n    short\t    Pid_s;\t\t//物理ＩＤ\n    short\t    PcsIdx_s;\t\t//PCSインデックス\n\n    D( DP1_(\"MO11RV ＭＰＢ全情報データ判定処理\\n\"); )\n\n    Sid_s = pMpba[0];\t\t\t//ステーションＩＤ\n    Pid_s = pMpba[1];\t\t\t//計器分類＋物理ＩＤ\n\n    //ステーションＩＤ範囲チェック\n    if ((1 > Sid_s) || (CNF_MAX_ADAPCS_N < Sid_s)) return SS_FALSE_P;\n\n    //計器分類チェック（計装でない場合はエラー）\n    if ((Pid_s & 0xF000) != 0x1000) return SS_FALSE_P;\n//  if ((Pid_s & 0x2000) != 0) return SS_FALSE_P;\n//  if ((Pid_s & 0x1000) == 0) return SS_FALSE_P;\n\n    //計器分類部を除外する。\n    Pid_s = (Pid_s & 0x0FFF) + 1;\n\n    PcsIdx_s = Sid_s - 1;\n\n    //ＰＣＳ実装チェック 未実装の場合はエラー\n    if (SS_ENTRY_P != JD_loc[PcsIdx_s].inf_us)\t    return SS_FALSE_P;\n\n    //回線種別がADA4000でない場合はエラー\n    if (JD_NET_ADA_P != JD_loc[PcsIdx_s].netknd_us) return SS_FALSE_P;\n\n    //ノード種別がVPCSの場合はエラー\n    if ((JD_STN_VPCS_P == JD_loc[PcsIdx_s].nodes_us) ||\n       (JD_STN_VPCS_2_P == JD_loc[PcsIdx_s].nodes_us)) return SS_FALSE_P;\n\n    //ＰＣＳ種別がサポート外の場合はエラー(ADC4000,ADC5000,VC5000,VC100)\n    if ((JD_loc[PcsIdx_s].tyopcs_us != JD_A4K_P\t ) &&\n\t(JD_loc[PcsIdx_s].tyopcs_us != JD_A5K_P\t ) &&\n\t(JD_loc[PcsIdx_s].tyopcs_us != JD_RC5_P)) return SS_FALSE_P;\n\t\n\t//最大物理ＩＤチック\n\tif (JD_loc[PcsIdx_s].skiki_us >= CNF_KEIKI_N) return SS_FALSE_P;\n    \n    //物理ＩＤ範囲チェック\n    if ((1 > Pid_s) || ((JD_loc[PcsIdx_s].skiki_us + 1) < Pid_s)) return SS_FALSE_P;\n\n    //下記の２つはやろうかとも思ったのですが、P-NET(Ethernet)側が\n    //\tやってないようなのではずしています。\n\t//監視グループ外\n\t//ＰＣＳロック\n\n    *pSid_s = Sid_s;\n    *pPid_s = Pid_s;\n\n    return SS_TRUE_P;\n}\n\n//------------------------------------------------------------------------------\n//マンマシンコマンドデータ受信時処理\n//------------------------------------------------------------------------------\nvoid f_11rv400(union U_ONE_BUF* pOneBuf)\n{\n    int\t\t\t    Rsts_i;\t    //リターンステータス\n    int\t\t\t    Size_i;     //サイズ\n\n    D( DP1_(\"MO11RV マンマシンコマンドデータ受信\\n\"); )\n\n    //受信データサイズ不正\n    if ( (z_pOne->transfer.datalen < (S_HSZ+S_MSZ)) ||\n         (z_pOne->transfer.datalen > (S_HSZ+S_MSZ+sizeof(z_cmdAns.text_s))) ) {\n\t    F_errlog( 0x1000, 0x4001, z_pOne->transfer.nodenum, z_pOne->transfer.datalen, 0, 0,\n\t              \"受信データ数不正(INF1:Node,INF2:Size)\");\n\t    return;\n    }\n\n    \n    //要求元がPCSモニタでなければ\n    if (pOneBuf->mhd.root_us[2] == 0xffff) return;\n\n\tmemset( &z_cmdAns, 0, sizeof(struct Q_T_GPCSM_MAN) );\n\tmemcpy( &z_cmdAns.mh\n\t\t, &pOneBuf->byte_uc[S_HSZ]\n\t, (z_pOne->transfer.datalen - S_HSZ) );\n\tmemcpy( &z_cmdAns.qh.clntip_ul\n\t\t, &(pOneBuf->mhd.root_us[0])\n\t\t, sizeof(unsigned long));           //クライアントIP\n\tz_cmdAns.qh.winid_s = \n\t\tpOneBuf->mhd.root_us[2];            //ウィンドウID\n\tz_cmdAns.qh.gkind_s = SS_DLLPCSMON_P;   //画面種別をPCSモニタ指定\n\tz_cmdAns.qkey_t     = Q_GSCRM_KEY1;     //送信先画面管理タスク\n\tz_cmdAns.qh.func_s = QF_GPCSM_MAN_P;    //マンマシンデータ応答\n\n    Size_i = sizeof(struct Q_T_GPCSM_MAN);\n    Rsts_i = F_quemgr( QUE_ENQ_P | QUE_NOWAIT_P, Q_GSCRM_KEY1,\n\t\t       &z_cmdAns, &Size_i );\n    if (RS_SUC != Rsts_i) {\n\t    F_errlog( 0x0131, 0x4002, Rsts_i, 0, 0, 0,\n\t              \"データ変更通知(マンマシンデータ応答)失敗(INF1:Stat)\");\n    }\n\n}\n","structuredPatch":[{"oldStart":1,"oldLines":6,"newStart":1,"newLines":6,"lines":[" //++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++"," // *****************************************************************************","-// *                Copyright Meidensha Corporation 2009                       *","+// *                Copyright Meidensha Corporation 2009                        *"," // *  株式会社明電舎は当社によって提供されない装置上での当ソフトウェアの使用   *"," // *  に対し責任を全く負いません。                                             *"," // *****************************************************************************"]}],"userModified":false,"replaceAll":false},"sourceToolAssistantUUID":"dc397669-0e2e-42dd-8e24-874878787b41"}
