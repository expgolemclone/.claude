{"parentUuid":"2af4dce6-b89d-4532-91a2-f2217d936acf","isSidechain":false,"userType":"external","cwd":"D:\\refactoring\\ops5k_x64","sessionId":"21dcb8cf-8000-4bfc-8873-a80df640fa6c","version":"2.1.62","gitBranch":"main","slug":"robust-waddling-treehouse","message":{"model":"claude-opus-4-6","id":"msg_01PZ5ZJCB73PwkfVRnf9DuE2","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01McUfn7RDSs73Eduw6E86Bq","name":"Write","input":{"file_path":"D:\\refactoring\\ops5k_x64\\.hooks\\check_encoding.py","content":"\"\"\"PostToolUse hook: detect encoding changes in source files.\n\nCompares the file's encoding after Edit/Write against the HEAD version in git.\nIf the encoding changed (e.g. cp932 -> utf-8), outputs a warning to stdout\nwhich Claude will see as feedback.\n\"\"\"\n\nimport json\nimport os\nimport subprocess\nimport sys\n\n\nSOURCE_EXTS = {\".c\", \".h\", \".cpp\", \".hpp\"}\n\n\ndef detect_encoding(data: bytes) -> str | None:\n    \"\"\"Detect encoding by trying cp932 then utf-8.\"\"\"\n    for enc in (\"cp932\", \"utf-8\"):\n        try:\n            data.decode(enc)\n            return enc\n        except (UnicodeDecodeError, ValueError):\n            continue\n    return None\n\n\ndef is_binary(data: bytes) -> bool:\n    return b\"\\x00\" in data[:512]\n\n\ndef get_git_head_content(rel_path: str, cwd: str) -> bytes | None:\n    \"\"\"Get file content from git HEAD.\"\"\"\n    try:\n        result = subprocess.run(\n            [\"git\", \"show\", f\"HEAD:{rel_path}\"],\n            capture_output=True,\n            cwd=cwd,\n        )\n        if result.returncode == 0:\n            return result.stdout\n    except Exception:\n        pass\n    return None\n\n\ndef get_repo_root(cwd: str) -> str | None:\n    try:\n        result = subprocess.run(\n            [\"git\", \"rev-parse\", \"--show-toplevel\"],\n            capture_output=True,\n            text=True,\n            cwd=cwd,\n        )\n        if result.returncode == 0:\n            return result.stdout.strip()\n    except Exception:\n        pass\n    return None\n\n\ndef main() -> int:\n    input_data = json.load(sys.stdin)\n    tool_input = input_data.get(\"tool_input\", {})\n    file_path = tool_input.get(\"file_path\", \"\")\n    cwd = input_data.get(\"cwd\", \"\")\n\n    if not file_path or not os.path.isfile(file_path):\n        return 0\n\n    # Only check source files\n    ext = os.path.splitext(file_path)[1].lower()\n    if ext not in SOURCE_EXTS:\n        return 0\n\n    # Read current file\n    try:\n        with open(file_path, \"rb\") as f:\n            current_data = f.read()\n    except OSError:\n        return 0\n\n    if not current_data or is_binary(current_data):\n        return 0\n\n    # Get repo root and relative path\n    repo_root = get_repo_root(cwd)\n    if not repo_root:\n        return 0\n\n    # Normalize to forward slashes for git\n    abs_path = os.path.abspath(file_path)\n    rel_path = os.path.relpath(abs_path, repo_root).replace(\"\\\\\", \"/\")\n\n    # Get original from HEAD\n    original_data = get_git_head_content(rel_path, repo_root)\n    if original_data is None:\n        return 0  # New file, not in git yet\n\n    orig_enc = detect_encoding(original_data)\n    curr_enc = detect_encoding(current_data)\n\n    if orig_enc and curr_enc and orig_enc != curr_enc:\n        print(\n            f\"WARNING: ENCODING CHANGED: {file_path}\\n\"\n            f\"  Original(HEAD): {orig_enc} -> Current: {curr_enc}\\n\"\n            f\"  文字コードが変更されています。元のエンコーディング({orig_enc})に戻してください。\\n\"\n            f\"  このファイルを{orig_enc}で保存し直す必要があります。\"\n        )\n\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":464,"cache_read_input_tokens":36622,"output_tokens":1084,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creat