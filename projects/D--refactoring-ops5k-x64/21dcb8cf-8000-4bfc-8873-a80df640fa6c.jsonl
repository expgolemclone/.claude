    NULL,\t\n                \"�x���~�v���p�t�d���M���s\");      //\n        }\n\n    }\n\n    return;\n\n}\n\n// ****************************************************************************\n// *�h�c      *��  ��                                            *�֐���      *\n// *  �T�D�P  *    PCS�x���~�o��                               * f_alm510   *\n// ****************************************************************************\n//\n//  �@  �\\:\n//      PCS�x���~�o�͂�����B\n//\n//  �R�[�����O�V�[�P���X:\n//     void f_alm510(void);\n//\n//  ���̓f�[�^:\n//      �Ȃ�\n//\n//  �o�̓f�[�^:\n//     �Ȃ�\n//\n//  �߂�l:\n//      �Ȃ�\n//\n//  �������e�F\n//      PCS�ւ̌x���~�o�͂��s��\n//\n//-----------------------------------------------------------------------------\nvoid f_alm510()\n{\n    int                     sts_i;\n    struct Q_T_JSEND_KIK    que;\n    int                     siz_i = sizeof(struct Q_T_JSEND_KIK);\n    int                     cnt_i;\n\n    //�o�͖����Ȃ�ΏI���\n    if (z_Plcout_i == 0) return ;\n\n    //����ID�ϊ�\n    for (cnt_i = 0; cnt_i < S_MAXCNT_DATANO; cnt_i++) {\n        //��ʂ��@��^�O\n        if (almstop[cnt_i].logno_s[0] == SYS_KIKI_P) {\n            //���䷭��쐬\n            memset(&que, 0, sizeof(que));\n            que.qh.func_s = QF_JSEND_KIK_P;         // QUE�t�@���N�V����\n            que.qh.sfnc_s = 0;                      // QUE�T�u�t�@���N�V����\n            que.qh.sdpr_s = TN_AOALM;               // ���M���v���Z�XID   \n            que.pcs_us = almstop[cnt_i].logno_s[1]; // �o�b�r�ԍ�\n            que.id_us  = almstop[cnt_i].logno_s[2]; // �v��ԍ��i����ID�j\n            que.mpb_us = QL_JSEND_DO_P;             // �l�o�a�I�t�Z�b�g\n                                                    // ����f�[�^\n            que.dat_us = (0x0001 << (almstop[cnt_i].outdata_i - 1));\n            que.srf_us = que.dat_us;                // �r�q�e�f�[�^      \n            que.que_us = QL_JSEND_NULL_P;           // �ʒm�p�t�d �j�d�x \n            que.ord_us = QL_JSEND_