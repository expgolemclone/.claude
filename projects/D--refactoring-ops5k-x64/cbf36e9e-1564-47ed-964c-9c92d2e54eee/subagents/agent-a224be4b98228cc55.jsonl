{"parentUuid":"98c4b7d8-c16b-4396-a22b-3dd7ebf1e568","isSidechain":true,"userType":"external","cwd":"D:\\refactoring\\ops5k_x64","sessionId":"cbf36e9e-1564-47ed-964c-9c92d2e54eee","version":"2.1.61","gitBranch":"main","agentId":"a224be4b98228cc55","slug":"expressive-strolling-blum","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TrWMFx7xWGMp74ZnRSjoNV","type":"tool_result","content":"     1→\"\"\"pre-commit hook: scan all tracked files against denylist patterns.\"\"\"\n     2→\n     3→import os\n     4→import re\n     5→import subprocess\n     6→import sys\n     7→\n     8→\n     9→def load_denylist(path: str) -> list[tuple[str, re.Pattern]]:\n    10→    \"\"\"Load patterns from the denylist file.\n    11→\n    12→    Returns:\n    13→        [(raw_pattern, compiled_regex), ...]\n    14→    \"\"\"\n    15→    if not os.path.isfile(path):\n    16→        raise RuntimeError(f\"denylist file not found: {path}\")\n    17→\n    18→    patterns = []\n    19→    with open(path, \"r\", encoding=\"utf-8\") as f:\n    20→        for line in f:\n    21→            line = line.strip()\n    22→            if not line or line.startswith(\"#\"):\n    23→                continue\n    24→            patterns.append((line, re.compile(line)))\n    25→    return patterns\n    26→\n    27→\n    28→def tracked_files() -> list[str]:\n    29→    \"\"\"Return all tracked files via git ls-files.\"\"\"\n    30→    result = subprocess.run(\n    31→        [\"git\", \"ls-files\", \"-z\", \"--\", \"src/\"],\n    32→        capture_output=True,\n    33→    )\n    34→    if result.returncode != 0:\n    35→        raise RuntimeError(f\"git ls-files failed: {result.stderr.decode()}\")\n    36→    raw = result.stdout\n    37→    if not raw:\n    38→        return []\n    39→    return [p for p in raw.decode(\"utf-8\").split(\"\\0\") if p]\n    40→\n    41→\n    42→def is_binary(data: bytes) -> bool:\n    43→    \"\"\"True if null byte found in the first 512 bytes.\"\"\"\n    44→    return b\"\\x00\" in data[:512]\n    45→\n    46→\n    47→def scan_file(\n    48→    filepath: str,\n    49→    combined: re.Pattern,\n    50→    patterns: list[tuple[str, re.Pattern]],\n    51→) -> list[tuple[int, str, str]]:\n    52→    \"\"\"Scan a file and return violations.\n    53→\n    54→    Returns:\n    55→        [(line_number, line_content, pattern_str), ...]\n    56→    \"\"\"\n    57→    try:\n    58→        data = open(filepath, \"rb\").read()\n    59→    except OSError:\n    60→        return []\n    61→\n    62→    if not data or is_binary(data):\n    63→        return []\n    64→\n    65→    # Decode: cp932 -> utf-8 -> latin-1 fallback\n    66→    text = None\n    67→    for enc in (\"cp932\", \"utf-8\"):\n    68→        try:\n    69→            text = data.decode(enc)\n    70→            break\n    71→        except (UnicodeDecodeError, ValueError):\n    72→            continue\n    73→    if text is None:\n    74→        text = data.decode(\"latin-1\")\n    75→\n    76→    violations = []\n    77→    for lineno, line in enumerate(text.splitlines(), start=1):\n    78→        if not combined.search(line):\n    79→            continue\n    80→        for raw, pat in patterns:\n    81→            if pat.search(line):\n    82→                violations.append((lineno, line.rstrip(), raw))\n    83→\n    84→    return violations\n    85→\n    86→\n    87→def main() -> int:\n    88→    hooks_dir = os.path.dirname(os.path.abspath(__file__))\n    89→    denylist_path = os.path.join(hooks_dir, \".denylist\")\n    90→\n    91→    patterns = load_denylist(denylist_path)\n    92→    if not patterns:\n    93→        print(\"  denylist is empty, skipping.\")\n    94→        return 0\n    95→\n    96→    # Combined pattern for fast pre-screening\n    97→    combined_raw = \"|\".join(f\"(?:{raw})\" for raw, _ in patterns)\n    98→    combined = re.compile(combined_raw)\n    99→\n   100→    files = tracked_files()\n   101→    if not files:\n   102→        print(\"  no tracked files.\")\n   103→        return 0\n   104→\n   105→    # Collect violations per file\n   106→    all_violations: dict[str, list[tuple[int, str, str]]] = {}\n   107→    for f in files:\n   108→        if not os.path.isfile(f):\n   109→            continue\n   110→        hits = scan_file(f, combined, patterns)\n   111→        if hits:\n   112→            all_violations[f] = hits\n   113→\n   114→    if not all_violations:\n   115→        print(\"  no denylist violations found.\")\n   116→        return 0\n   117→\n   118→    # Report\n   119→    total = sum(len(v) for v in all_violations.values())\n   120→    print(f\"\\nDENYLIST: {total} violation(s) in {len(all_violations)} file(s):\\n\")\n   121→    for filepath, hits in sorted(all_violations.items()):\n   122→        print(f\"  {filepath}:\")\n   123→        for lineno, line, pat in hits:\n   124→            # Truncate long lines\n   125→            display = line if len(line) <= 120 else line[:117] + \"...\"\n   126→            print(f\"    L{lineno}: [{pat}] {display}\")\n   127→        print()\n   128→\n   129→    return 1\n   130→\n   131→\n   132→if __name__ == \"__main__\":\n   133→    sys.exit(main())\n   134→"}]},"uuid":"2e879bfb-aaa9-4cba-97f1-4884accb3cf7","timestamp":"2026-02-27T01:33:22.649Z","sourceToolAssistantUUID":"98c4b7d8-c16b-4396-a22b-3dd7ebf1e568"}
