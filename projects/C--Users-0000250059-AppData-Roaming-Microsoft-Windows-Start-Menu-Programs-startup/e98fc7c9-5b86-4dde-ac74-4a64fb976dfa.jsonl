\"https://claude.ai\"]\nc.url.default_page = \"https://claude.ai\"\n\n# 検索エンジン\nc.url.searchengines = {\"DEFAULT\": \"https://www.google.com/search?q={}\"}\n\n# Bitwarden パスワード自動入力\nconfig.bind('<Alt-p>', 'spawn --userscript qute-bitwarden.bat')\n\n# YouTube を mpv で再生（広告なし）\nconfig.bind('<Alt-m>', 'spawn --userscript open-in-mpv.bat')\n","numLines":44,"startLine":1,"totalLines":44}},"sourceToolAssistantUUID":"b893bfac-6c0b-422d-a0cd-5120b89fe959"}
