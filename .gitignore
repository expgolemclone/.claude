# Whitelist approach: ignore everything, then allow specific files
*

# Allow .gitignore itself
!.gitignore

# Setup script (generates OS-specific settings.json)
!setup.py
!CLAUDE.md
!settings.json

# Hooks (custom scripts)
!hooks/
!hooks/**
hooks/__pycache__/

# Rules (per-language coding rules)
!rules/
!rules/**

# Tests
!tests/
!tests/**
tests/__pycache__/

# Scripts
!scripts/
!scripts/**

