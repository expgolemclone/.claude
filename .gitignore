# Whitelist approach: ignore everything, then allow specific files
*

# Allow .gitignore itself
!.gitignore

# Documentation
!ARCHITECTURE.md
!CLAUDE.md

# Config
!keybindings.json
settings.json

# Rust hooks
!hooks-rs/
!hooks-rs/**
hooks-rs/target/

# Config (runtime hook settings)
!config/
!config/**

# Claude Code personal skills
!skills/
!skills/**

# Data
!data/
!data/scrape.db

# Scripts
!scripts/
!scripts/**
scripts/result
