# Whitelist approach: ignore everything, then allow specific files
*

# Allow .gitignore itself
!.gitignore

# Setup script and config
!setup.py
!pyproject.toml
settings.json

# Hooks (custom scripts)
!hooks/
!hooks/**
hooks/__pycache__/

# Rules (per-language coding rules)
!rules/
!rules/**

# Tests
!tests/
!tests/**
tests/__pycache__/

# Scripts
!scripts/
!scripts/**

