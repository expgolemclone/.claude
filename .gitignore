# Whitelist approach: ignore everything, then allow specific files
*

# Allow .gitignore itself
!.gitignore
!.gitattributes

# Setup script and config
!setup.py
!setup_claude.py
!pyproject.toml
settings.json

# Hooks (custom scripts)
!hooks/
!hooks/**
hooks/__pycache__/

# Config (per-language coding rules & settings)
!config/
!config/**

# Data
!data/
!data/scrape.db

# Tests
!tests/
!tests/**
tests/__pycache__/
tests/benchmarks/**/public-apis/
tests/benchmarks/**/youtube-dl/

# Scripts
!scripts/
!scripts/**
scripts/__pycache__/
scripts/result
