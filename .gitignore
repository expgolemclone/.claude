# Whitelist approach: ignore everything, then allow specific files
*

# Allow .gitignore itself
!.gitignore
!.gitattributes

# Documentation
!ARCHITECTURE.md
!CLAUDE.md

# Python files and config
!*.py
!*.toml
!uv.lock
!keybindings.json
settings.json

# Hooks (custom scripts)
!hooks/
!hooks/**
hooks/__pycache__/

# Rust hooks
!hooks-rs/
!hooks-rs/**
hooks-rs/target/

# Config (per-language coding rules & settings)
!config/
!config/**

# Data
!data/
!data/scrape.db

# Tests
!tests/
!tests/**
tests/__pycache__/
tests/**/__pycache__/
tests/benchmarks/**/public-apis/
tests/benchmarks/**/youtube-dl/
tests/benchmarks/**/django/

# Scripts
!scripts/
!scripts/**
scripts/__pycache__/
scripts/result
