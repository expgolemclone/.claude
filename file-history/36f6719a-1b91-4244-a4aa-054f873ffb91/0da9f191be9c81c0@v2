#!/usr/bin/env python3
"""
Arc Browser -> qutebrowser migration script (Windows)

Migrates:
  1. Bookmarks (Arc Chromium Bookmarks -> qutebrowser quickmarks + bookmarks)
  2. History (Arc History SQLite -> qutebrowser history.sqlite)
  3. Login Data -> CSV export (for import into a password manager)
"""

import json
import os
import shutil
import sqlite3
import csv
import tempfile
from datetime import datetime, timezone

# === Paths ===
ARC_BASE = os.path.join(
    os.environ["LOCALAPPDATA"],
    "Packages",
    "TheBrowserCompany.Arc_ttt1ap7aakyb4",
    "LocalCache",
    "Local",
    "Arc",
)
ARC_PROFILE = os.path.join(ARC_BASE, "User Data", "Default")
ARC_BOOKMARKS = os.path.join(ARC_PROFILE, "Bookmarks")
ARC_HISTORY = os.path.join(ARC_PROFILE, "History")
ARC_LOGINS = os.path.join(ARC_PROFILE, "Login Data")

# qutebrowser on Windows: config in %APPDATA%, data in %LOCALAPPDATA% (or both in %APPDATA%)
QB_CONFIG = os.path.join(os.environ["APPDATA"], "qutebrowser", "config")
QB_DATA = os.path.join(os.environ["APPDATA"], "qutebrowser", "data")

HOME = os.path.expanduser("~")
EXPORT_DIR = os.path.join(HOME, "arc_migration_export")


def ensure_dirs():
    os.makedirs(QB_CONFIG, exist_ok=True)
    os.makedirs(QB_DATA, exist_ok=True)
    os.makedirs(EXPORT_DIR, exist_ok=True)
    print(f"[OK] Created directories:")
    print(f"     config: {QB_CONFIG}")
    print(f"     data:   {QB_DATA}")
    print(f"     export: {EXPORT_DIR}")


# ============================================================
# 1. Bookmarks Migration
# ============================================================
def collect_bookmarks(node, folder=""):
    """Recursively collect bookmarks from Chromium Bookmarks JSON."""
    results = []
    name = node.get("name", "")
    current_folder = f"{folder}/{name}" if folder else name

    if node.get("type") == "url":
        url = node.get("url", "")
        if url:
            results.append({"name": name, "url": url, "folder": folder})

    for child in node.get("children", []):
        results.extend(collect_bookmarks(child, current_folder))

    return results


def migrate_bookmarks():
    print("\n=== Migrating Bookmarks ===")
    if not os.path.exists(ARC_BOOKMARKS):
        print("[SKIP] Arc Bookmarks file not found")
        return

    with open(ARC_BOOKMARKS, "r", encoding="utf-8") as f:
        data = json.load(f)

    all_bookmarks = []
    for root_key in ["bookmark_bar", "other", "synced"]:
        root_node = data.get("roots", {}).get(root_key)
        if root_node:
            all_bookmarks.extend(collect_bookmarks(root_node))

    if not all_bookmarks:
        print("[SKIP] No bookmarks found")
        return

    # Write quickmarks (name -> url mapping, for :quickmark-load)
    quickmarks_path = os.path.join(QB_CONFIG, "quickmarks")
    with open(quickmarks_path, "w", encoding="utf-8") as f:
        for bm in all_bookmarks:
            # quickmarks format: "name url"
            safe_name = bm["name"].replace(" ", "_")[:50]
            f.write(f"{safe_name} {bm['url']}\n")

    # Write bookmarks (url + title, for :bookmark-list)
    bookmarks_path = os.path.join(QB_CONFIG, "bookmarks", "urls")
    os.makedirs(os.path.dirname(bookmarks_path), exist_ok=True)
    with open(bookmarks_path, "w", encoding="utf-8") as f:
        for bm in all_bookmarks:
            f.write(f"{bm['url']} {bm['name']}\n")

    print(f"[OK] Migrated {len(all_bookmarks)} bookmarks")
    print(f"     quickmarks: {quickmarks_path}")
    print(f"     bookmarks:  {bookmarks_path}")

    # Also export as HTML for backup
    html_path = os.path.join(EXPORT_DIR, "arc_bookmarks.html")
    with open(html_path, "w", encoding="utf-8") as f:
        f.write("<!DOCTYPE NETSCAPE-Bookmark-file-1>\n")
        f.write('<META HTTP-EQUIV="Content-Type" CONTENT="text/html; charset=UTF-8">\n')
        f.write("<TITLE>Bookmarks</TITLE>\n<H1>Bookmarks</H1>\n<DL><p>\n")
        for bm in all_bookmarks:
            f.write(f'  <DT><A HREF="{bm["url"]}">{bm["name"]}</A>\n')
        f.write("</DL><p>\n")
    print(f"     backup HTML: {html_path}")


# ============================================================
# 2. History Migration
# ============================================================
def chromium_time_to_unix(chromium_ts):
    """Convert Chromium timestamp (microseconds since 1601-01-01) to Unix timestamp."""
    # Chromium epoch: 1601-01-01 00:00:00 UTC
    # Difference to Unix epoch: 11644473600 seconds
    return (chromium_ts / 1_000_000) - 11644473600


def migrate_history():
    print("\n=== Migrating History ===")
    if not os.path.exists(ARC_HISTORY):
        print("[SKIP] Arc History file not found")
        return

    # Copy to temp to avoid locking issues
    tmp = os.path.join(tempfile.gettempdir(), "arc_history_migrate")
    shutil.copy2(ARC_HISTORY, tmp)

    src_conn = sqlite3.connect(tmp)
    src_cur = src_conn.cursor()

    # Read Arc history
    src_cur.execute(
        "SELECT url, title, last_visit_time, visit_count FROM urls ORDER BY last_visit_time"
    )
    rows = src_cur.fetchall()
    src_conn.close()

    if not rows:
        print("[SKIP] No history entries found")
        os.remove(tmp)
        return

    # Create qutebrowser history database
    qb_history_path = os.path.join(QB_DATA, "history.sqlite")
    dst_conn = sqlite3.connect(qb_history_path)
    dst_cur = dst_conn.cursor()

    # qutebrowser history schema
    dst_cur.execute("""
        CREATE TABLE IF NOT EXISTS History (
            url TEXT NOT NULL,
            title TEXT,
            atime REAL NOT NULL,
            redirect INTEGER NOT NULL DEFAULT 0
        )
    """)
    dst_cur.execute("""
        CREATE TABLE IF NOT EXISTS CompletionHistory (
            url TEXT NOT NULL,
            title TEXT,
            last_atime REAL NOT NULL
        )
    """)
    dst_cur.execute(
        "CREATE TABLE IF NOT EXISTS CompletionMetaInfo (key TEXT PRIMARY KEY, value TEXT)"
    )
    dst_cur.execute(
        "INSERT OR REPLACE INTO CompletionMetaInfo VALUES ('force_rebuild', '1')"
    )

    count = 0
    for url, title, last_visit_time, visit_count in rows:
        unix_ts = chromium_time_to_unix(last_visit_time)
        if unix_ts > 0:
            dst_cur.execute(
                "INSERT INTO History (url, title, atime, redirect) VALUES (?, ?, ?, 0)",
                (url, title or "", unix_ts),
            )
            count += 1

    dst_conn.commit()
    dst_conn.close()
    os.remove(tmp)

    print(f"[OK] Migrated {count} history entries")
    print(f"     history db: {qb_history_path}")


# ============================================================
# 3. Login Data Export (CSV for password manager import)
# ============================================================
def export_logins():
    print("\n=== Exporting Login Data ===")
    if not os.path.exists(ARC_LOGINS):
        print("[SKIP] Arc Login Data file not found")
        return

    tmp = os.path.join(tempfile.gettempdir(), "arc_login_migrate")
    shutil.copy2(ARC_LOGINS, tmp)

    conn = sqlite3.connect(tmp)
    cur = conn.cursor()
    cur.execute("SELECT origin_url, username_value, password_value FROM logins")
    rows = cur.fetchall()
    conn.close()
    os.remove(tmp)

    if not rows:
        print("[SKIP] No login entries found")
        return

    csv_path = os.path.join(EXPORT_DIR, "arc_logins.csv")
    with open(csv_path, "w", encoding="utf-8", newline="") as f:
        writer = csv.writer(f)
        writer.writerow(["url", "username", "password_encrypted"])
        for url, username, pwd_blob in rows:
            # Passwords are encrypted by Windows DPAPI - cannot decrypt directly
            # The password field will be empty/encrypted
            writer.writerow([url, username, "(encrypted - use Chrome export instead)"])

    print(f"[OK] Exported {len(rows)} login entries (URLs + usernames)")
    print(f"     csv: {csv_path}")
    print()
    print("  *** IMPORTANT: Passwords are encrypted by Windows DPAPI ***")
    print("  To export passwords with actual values:")
    print("  1. Open Arc Browser -> Settings -> Passwords")
    print("  2. Click the three-dot menu -> Export passwords")
    print("  3. Import the CSV into Bitwarden / KeePassXC / 1Password")
    print("  qutebrowser does not have a built-in password manager.")
    print("  Recommended: Install Bitwarden browser extension via greasemonkey")
    print("  or use qutebrowser's :spawn pass integration.")


# ============================================================
# Main
# ============================================================
def main():
    print("=" * 60)
    print("  Arc Browser -> qutebrowser Migration Tool")
    print("=" * 60)

    ensure_dirs()
    migrate_bookmarks()
    migrate_history()
    export_logins()

    print()
    print("=" * 60)
    print("  Migration Complete!")
    print("=" * 60)
    print()
    print("Next steps:")
    print("  1. Launch qutebrowser to verify bookmarks: :quickmark-list or :bookmark-list")
    print("  2. Check history with :history")
    print("  3. For passwords, export from Arc and import into a password manager")
    print(f"  4. Backup HTML bookmarks saved at: {EXPORT_DIR}")


if __name__ == "__main__":
    main()
