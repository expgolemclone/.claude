# ===========================================================
#  .gitattributes — 改行コード・バイナリ判定の Git レベル設定
# ===========================================================
# このプロジェクトは CP932 + CRLF を標準とする。
# エンコーディング変換は pre-commit フック (pre_commit_encoding.py) が担当。
# ここでは改行コード (eol) とバイナリ/テキスト判定を Git に指示する。

# ---- デフォルト: テキストファイルは CRLF ----
* text=auto eol=crlf

# ---- バイナリファイル (変換しない) ----
*.gif    binary
*.GIF    binary
*.ico    binary
*.bmp    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.wav    binary
*.cur    binary

*.dll    binary
*.DLL    binary
*.exe    binary
*.lib    binary
*.Lib    binary
*.tlb    binary
*.bin    binary

*.xlsx   binary
*.xlsm   binary
*.xlsb   binary
*.xls    binary
*.docx   binary
*.doc    binary
*.pdf    binary

*.zip    binary
*.snk    binary
*.pfx    binary
*.pvk    binary
*.cer    binary

*.suo    binary
*.EUF    binary
*.TTE    binary
*.STB    binary
*.HLP    binary
*.chm    binary
*.cnt    binary

*.MSG    binary
*.msg    binary

*.frx    binary
*.dat    binary
*.acf    binary
