#include    "Genset.h"                          /* пњљё™пњљЏ∞пњљпњљпњљпњљ Тпњљ`           */

/*+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
 *  пњљ@  пњљ\пњљF
 *      пњљdпњљmпњљrпњљfпњљ[пњљ^пњљпњљпњљbпњљrпњљuпњљ…ЛtпњљѕКпњљпњљпњљпњљпњљ
 *  calling sequence:
 *      (int) Genset600(doc_b) ;
 *  пњљпњљ  пњљЌБF
 *      BOOL  doc_b      : пњљhпњљLпњљпњљпњљпњљпњљпњљпњљgпњљмРђпњљпњљпњљпњљ TRUE
 *  пњљo  пњљЌБF
 *      пњљ»Впњљ
 *  пњљяВпњљlпњљF
 *      RS_SUC    : пњљпњљпњљпњљпњљпњљпњљпњљ
 *      RS_ERR    : пњљпњљпњљпњљпњљпњљпњљs
 *+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
int Genset600(BOOL doc_b)
{
  char    full_c[S_PATHSIZE],                   /*                           */
          path_c[S_PATHSIZE],                   /*                           */
          path2_c[S_PATHSIZE],                  /*                           */
          fname_c[S_FILESIZE] ;                 /*                           */
  short   stn_s, dname_s, bk_s, ops_s ;         /*                           */
  short   type_s ;                              /* пњљпњљпњљ—Опњљпњљ                  */
  int     i, j ;                                /*                          */
//  BOOL    kiki_b ;                              /*                           */
  FILE    *fp[5] ;                              /*                           */
  T_def   def ;                                 /*                           */
  T_FCTY  fcty[CNF_FCTY_N + 1] ;                /*                           */
  char    *dname_c[] =                          /* пњљё∞пњљћІпњљўЦпњљ                */
    {"Nibkiki", "Nibkiast", "Pcskiki", "Pcskiast",
     "Nibkeso", "Nibksast", "Pcskeso", "Pcsksast"} ;
  struct _finddata_t fileinfo ;                 /*                           */
  char *str_cp;																	// TA002 add
  size_t env_len;
  char env_buf[256];
                                                /*                           */
                                                /*                           */
  if(doc_b) {                                   /* пњљёЈпњљпњљпњљƒНмРђ(ћІпњљўНнПЬ)     */
    getenv_s(&env_len, env_buf, sizeof(env_buf), "GENEDT_MODE");
    str_cp = env_buf;
	if (env_len == 0 || strcmp(str_cp, "Document_Graph") != 0) {				// TA002 add
      for (i=0; i<2; i++) {                     /*   (пњљпњљпњљпњљ:пњљOпњљпњљ)             */
        sprintf(path2_c, "%s%s\\", z_path_doc, i?"pcs":"naibu") ;
        sprintf(full_c, "del %s*.csv > NUL", path2_c) ;
        system(full_c) ;                        /*                           */
      }                                         /*                           */
	}																			// TA002 add
	else {																		// TA002 add
	  sprintf(full_c, "del %sпњљпњљпњљ\\*.csv > NUL", z_path_doc);					// TA002 add
	  system(full_c);															// TA002 add
	}																			// TA002 add
  }                                             /*                           */
  else {                                        /* пњљ ПпњљмРђ(ћІпњљўНнПЬ)        */
    sprintf(full_c, "del %s*.csv > NUL", z_path_dat) ;
    system(full_c) ;                            /*                           */
  }                                             /*                           */
                                                /*                           */
  if (Genset401(&def)) return (RS_ERR) ;        /* пњљЁТпњљћІпњљўВпњљпњљпњљ«Впњљ          */
  memset(fcty, 0, sizeof(fcty)) ;               /*                           */
                                                /*                           */
  for (i=0; i<2; i++) {                         /* пњљPпњљ Цпњљпњљпњљ:пњљЁФпњљпњљпњљпњљћУ«ВЁНпњљпњљпњљ */
    sprintf(full_c, "%sdat00\\%s", z_path_file, i == 0 ? "Unit": "Fcty") ;
    if ((fp[4] = fopen(full_c, "rb")) == NULL){ /*                           */
      err_msg(full_c, " пњљпњљпњљ»Впњљпњљ≈Впњљ", "", 1) ;   /*                           */
    }                                           /*                           */
    else {                                      /*                           */
      if (i == 0) fread(def.eunit, sizeof(def.eunit), 1, fp[4]) ;
      else        fread(fcty, sizeof(fcty), 1, fp[4]) ;
      fclose (fp[4]) ;                          /*                           */
    }                                           /*                           */
  }                                             /* (for i)                   */
                                                /*                           */
  for (i=0; i<S_STATION*2; i++) {               /*                           */
                                                /*                           */
    stn_s = i % S_STATION ;                     /* пњљ√∞пњљпњљЁОжУЊ                */
    dname_s = (i<S_STATION?0:4) ;               /* DBћІпњљўЦпњљпњљпњљпњљя≤пњљпњљ           */
                                                /*                           */
	if(doc_b) {                                 /* пњљёЈпњљпњљпњљƒНмРђпњљяљ(пњљпњљпњљпњљ:пњљOпњљпњљ) */ // TA002 mod
      getenv_s(&env_len, env_buf, sizeof(env_buf), "GENEDT_MODE");
      str_cp = env_buf;
	  if (env_len == 0 || strcmp(str_cp, "Document_Graph") != 0) {			// TA002 add
        sprintf(path2_c, "%s%s\\", z_path_doc, stn_s ? "pcs":"naibu") ;
	  }																			// TA002 add
	  else {																	// TA002 add
	    sprintf(path2_c, "%sпњљпњљпњљ\\", z_path_doc);								// TA002 add
	  }																			// TA002 add
	}																			// TA002 add
    else                                        /* пњљ ПпњљмРђпњљяљ               */
      sprintf(path2_c, "%s", z_path_dat) ;      /*                           */
                                                /*                           */
    if (stn_s == 0) {                           /* пњљпњљпњљпњљпњљпњљёЛtпњљѕКпњљ             */
                                                /*                           */
      for (ops_s = 1;                           /* OPS1пњљ`16пњљћЛtпњљѕКпњљ          */
           ops_s <= CNF_MAXOPS_N;               /*                           */
           ops_s++) {                           /*                           */
                                                /*                           */
        type_s = def.type_s[ops_s-1] ;          /* пњљпњљпњљ—Опњљпњљ                  */
        if (type_s == 0) continue ;             /* пњљWпњљJпњљпњљпњљ»ВпњљпњљкНЗ            */
                                                /*                           */
                                                /* пњљё∞пњљпњљ«Нпњљпњљяљ               */
        sprintf(path_c, "%sdat%02d\\", z_path_file, ops_s) ;
                                                /*                           */
        if (_findfirst(path_c, &fileinfo) != -1){
          err_msg(path_c, " пњљпњљпњљ»Впњљпњљ≈Впњљ", "", 1) ;
          continue ;                            /*                           */
        }                                       /*                           */
                                                /*                           */
        for (j=0; j<2; j++) {                   /* пњљпњљпњљпњљ:пњљtпњљпњљпњљпњљпњљћІпњљпњљ       */
                                                /*                           */
          sprintf(full_c, "%s%s%02d", path_c, dname_c[dname_s+j], ops_s) ;
                                                /*                           */
          if ((fp[j] = fopen(full_c, "rb")) == NULL) {
            err_msg(full_c, " пњљпњљпњљ»Впњљпњљ≈Впњљ", "", 1) ;
            if (j == 1) fclose (fp[0]) ;        /*                           */
            break ;                             /*                           */
          }                                     /*                           */
        }                                       /*                           */
        if (j < 2) continue ;                   /*                           */
                                                /*                           */
        for (j=0; j<=type_s; j++) {             /* пњљпњљпњљпњљ0,пњљпњљпњљ@(пњљv)1,пњљпњљпњљ@(пњљv)2 */
                                                /*                           */
          if (i < S_STATION) {                  /* пњљ@пњљпњљпњљпњљпњљ                   */
            if (j==0) sprintf(fname_c, "пњљпњљпњљпњљ0%02d", ops_s) ;
            else if (j>1) continue;             /*                           */	// TA001 пњљпњљпњљ@пњљпњљ1пњљ№В≈БA2пњљЌВ»Впњљ
            else      sprintf(fname_c, "пњљпњљпњљ@%1d%02d", j, ops_s) ;
          }                                     /*                           */
          else {                                /* пњљvпњљпњљпњљпњљпњљ                   */
            if (j==0) continue ;                /*   пњљпњљпњљ”ВЌВ»Впњљ              */
            else      sprintf(fname_c, "пњљпњљпњљv%1d%02d", j, ops_s) ;
          }                                     /*                           */
                                                /*                           */
          printf("%s пњљtпњљѕКпњљпњљпњљ\n", fname_c) ;    /*                           */
                                                /*                           */
          sprintf(full_c, "%s%s_1.csv", path2_c, fname_c) ;
          if ((fp[2] = fopen(full_c, "w")) != NULL) {
                                                /*                           */
            sprintf(full_c, "%s%s_4.csv", path2_c, fname_c) ;
            if ((fp[3] = fopen(full_c, "w")) != NULL) {
                                                /*                           */
              if (i < S_STATION)                /* пњљ@пњљпњљпњљпњљпњљ                   */
                Genset610(fp, fcty, &def, (short)j, stn_s) ;
              else                              /* пњљvпњљпњљпњљпњљпњљ                   */
                Genset620(fp, fcty, &def, (short)j, stn_s) ;
                                                /*                           */
              fclose (fp[3]) ;                  /*                           */
            }                                   /*                           */
            else {                              /*                           */
              err_msg(full_c, " пњљпњљпњљпњљпњљ»Впњљпњљ≈Впњљ", "", 1) ;
            }                                   /*                           */
            fclose (fp[2]) ;                    /*                           */
          }                                     /*                           */
          else {                                /*                           */
            err_msg(full_c, " пњљпњљпњљпњљпњљ»Впњљпњљ≈Впњљ", "", 1) ;
          }                                     /*                           */
        }                                       /*  (for j)                  */
        fclose (fp[0]) ;                        /*                           */
        fclose (fp[1]) ;                        /*                           */
      }                                         /* (for ops_s)               */
    }                                           /* пњљпњљпњљпњљпњљпњљёЛtпњљѕКпњљпњљIпњљпњљ         */
    else {                                      /* пњљOпњљпњљпњљпњљёЛtпњљѕКпњљ             */
      /* JPLC002 [S] */
      /*  if(stn_s <= 32){ */                   /*                           */
      if(stn_s <= CNF_STATION_N){               /*                           */
      /* JPLC002 [E] */

     /* JPLC002 [S] */
	 /* bk_s = (i < S_STATION) ? 47 : 111 ; */  /*                           */	// TA001 "S_STATION - 3"пњљпњљ"S_STATION"
        bk_s = (i < S_STATION) ? 47 : 127 ;     /*                           */
     /* JPLC002 [E] */
                                                /*                           */
        if ((def.flag_i[stn_s+bk_s] & CHK_P) == 0)
          continue;                             /* пњљ«ВЁНпњљпњљпњљпњљпњљпњљпњљпњљ»Впњљ          */
                                                /* пњљё∞пњљпњљ«Нпњљпњљяљ               */
          sprintf(path_c, "%sdat00\\", z_path_file) ;
                                                /*                           */
          if (_findfirst(path_c, &fileinfo) != -1){ 
            err_msg(path_c, " пњљпњљпњљ»Впњљпњљ≈Впњљ", "", 1) ; 
            continue ;                          /*                           */
          }                                     /*                           */
                                                /*                           */
          for (j=0; j<2; j++) {                 /*  пњљпњљпњљпњљ:пњљtпњљпњљпњљпњљпњљћІпњљпњљ      */
                                                /*                           */
            sprintf(full_c, "%s%s", path_c, dname_c[dname_s+j+2]) ;
                                                /*                           */
            if ((fp[j] = fopen(full_c, "rb")) == NULL) {
              err_msg(full_c, " пњљпњљпњљ»Впњљпњљ≈Впњљ", "", 1);
              if (j == 1) fclose (fp[0]) ;      /*                           */
              break ;                           /*                           */
            }                                   /*                           */
          }                                     /*                           */
        if (j < 2) continue ;                   /*                           */
                                                /*                           */
        if (i < S_STATION)                      /* пњљ@пњљпњљпњљпњљпњљ                   */
          sprintf(fname_c, "пњљ@пњљпњљ%02d", stn_s) ; /*                           */
        else                                    /* пњљvпњљпњљпњљпњљпњљ                   */
          sprintf(fname_c, "пњљvпњљпњљ%02d", stn_s) ; /*                           */
                                                /*                           */
        printf("%s пњљtпњљѕКпњљпњљпњљ\n", fname_c) ;      /*                           */
                                                /*                           */
        sprintf(full_c, "%s%s_1.csv", path2_c, fname_c) ;
        if ((fp[2] = fopen(full_c, "w")) != NULL) {
                                                /*                           */
          sprintf(full_c, "%s%s_4.csv", path2_c, fname_c) ;
          if ((fp[3] = fopen(full_c, "w")) != NULL) {
                                                /*                           */
            if (i < S_STATION)                  /* пњљ@пњљпњљпњљпњљпњљ                   */
              Genset610(fp, fcty, &def, 0, stn_s);
            else                                /* пњљvпњљпњљпњљпњљпњљ                   */
              Genset620(fp, fcty, &def, 0, stn_s);
                                                /*                           */
            fclose (fp[3]) ;                    /*                           */
          }                                     /*                           */
          else {                                /*                           */
            err_msg(full_c, " пњљпњљпњљпњљпњљ»Впњљпњљ≈Впњљ", "", 1) ;
          }                                     /*                           */
        fclose (fp[2]) ;                        /*                           */
        }                                       /*                           */
        else {                                  /*                           */
          err_msg(full_c, " пњљпњљпњљпњљпњљ»Впњљпњљ≈Впњљ", "", 1) ;
        }                                       /*                           */
      fclose (fp[0]) ;                          /*                           */
      fclose (fp[1]) ;                          /*                           */
      }
    }                                           /* пњљOпњљпњљпњљпњљёЛtпњљѕКпњљпњљIпњљпњљ         */
  }                                             /* (for i)                   */
  return (RS_SUC) ;                             /*                           */
}                                               /*                           */
