#!/usr/bin/env python3
"""
Pattern E: strtok() → strtok_s() 一括置換スクリプト

処理内容:
  1. アクティブコード: strtok(str, delim) → strtok_s(str, delim, &strtok_ctx)
  2. コメント: strtok( → strtok_s(
  3. 宣言追加: 各関数先頭に char *strtok_ctx = NULL;

使い方:
  python replace_strtok.py
  (プロジェクトルートから実行)
"""
import re
import os

PROJECT_ROOT = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

# 対象ファイルリスト (38ファイル)
files = [
    'src/ens/Dll/lelogf_dll/Lelogf.c',
    'src/ens/botrdls/botrdls.c',
    'src/ens/ens_common/ens_common.c',
    'src/ens/le100/le100_mntr/Genset100.c',
    'src/gra/legmsdraw/LeGmsDraw.c',
    'src/gra/legrph/Legrph.c',
    'src/hoe/hoe/hoe_sub.c',
    'src/hoe/hoe/hoe_rcv_ssl.c',
    'src/hoe/hoe/hoe_rcv.c',
    'src/his/jorepfl/jorepfl.c',
    'src/sys/aosysi/aosysi.c',
    'src/sys/aomngr/aomngr.c',
    'src/sys/trdmov/trdmov.c',
    'src/sys/johubsts/johubsts.c',
    'src/mdc/mdcl160/mdcl160.c',
    'src/his/hstg120/hstg120.c',
    'src/ens/TF_config/TF_valinfset.c',
    'src/ens/lemmeq100/lemmeq100.cpp',
    'src/ens/TF_config/TF_subjectset.c',
    'src/ens/coalm100/coalm100.c',
    'src/sys/ini_GS/ini_GS_hcpalt.c',
    'src/sys/ini_GS/ini_GS_color.c',
    'src/sys/aoalm/aoalm.c',
    'src/NX_MW/opsnexus/init.c',
    'src/rep/fl_bnk/fl_bnkc01.c',
    'src/his/jorecs/jorecs.c',
    'src/msg/enq/enq.c',
    'src/msg/cotalk/ShQue.c',
    'src/tool/ErrorLog/erlgdsp.c',
    'src/his/hstsav/hstsav.c',
    'src/mdc/mssctl2/mssctl2_db_mscrn.c',
    'src/mdc/mssctl2/mssctl2_db_itvnm.c',
    'src/mdc/mssctl2/mssctl2.c',
    'src/msg/cotalk/f_csvread.c',
    'src/mdc/mssctl/mssctl_db_mscrn.c',
    'src/mdc/mssctl/mssctl.c',
    'src/mdc/mssctl/mssctl_cmdsend.c',
    'src/his/hstatst/hstatst_9000.c',
    'src/mdc/mssctl/mssctl_db_itvnm.c',
    'src/gra/graph/graph.cpp',
]


def read_file(filepath):
    """cp932 → utf-8 → latin-1 のフォールバックでファイル読み込み"""
    fullpath = os.path.join(PROJECT_ROOT, filepath)
    if not os.path.exists(fullpath):
        return None, None, fullpath
    raw = open(fullpath, 'rb').read()
    for enc in ['cp932', 'utf-8', 'latin-1']:
        try:
            return raw.decode(enc), enc, fullpath
        except UnicodeDecodeError:
            continue
    return None, None, fullpath


def write_file(fullpath, content, enc):
    """指定エンコーディングでファイル書き込み"""
    with open(fullpath, 'wb') as f:
        f.write(content.encode(enc))


def is_comment_line(line):
    """行がコメント行かどうかを判定"""
    stripped = line.strip()
    return stripped.startswith('//') or stripped.startswith('/*') or stripped.startswith('*')


def process_file(filepath):
    """strtok を strtok_s に置換"""
    content, enc, fullpath = read_file(filepath)
    if content is None:
        print(f'  SKIP: {filepath}')
        return 0

    original = content
    lines = content.split('\n')
    new_lines = []
    count = 0

    for line in lines:
        if 'strtok' not in line or 'strtok_s' in line:
            new_lines.append(line)
            continue

        if is_comment_line(line):
            # コメント行: strtok( → strtok_s(
            new_line = line.replace('strtok(', 'strtok_s(')
            if new_line != line:
                count += 1
            # strtok のみ (括弧なし) もカバー
            if 'strtok' in new_line and 'strtok_s' not in new_line:
                new_line = re.sub(r'\bstrtok\b', 'strtok_s', new_line)
                count += 1
            new_lines.append(new_line)
        else:
            # アクティブコード: strtok(args) → strtok_s(args, &strtok_ctx)
            # 最後の ) の直前に , &strtok_ctx を挿入
            def replace_strtok_call(m):
                nonlocal count
                count += 1
                call = m.group(0)
                # 最後の ) を見つけて , &strtok_ctx を挿入
                # strtok(str, delim) → strtok_s(str, delim, &strtok_ctx)
                depth = 0
                last_paren = -1
                for i, ch in enumerate(call):
                    if ch == '(':
                        depth += 1
                    elif ch == ')':
                        depth -= 1
                        if depth == 0:
                            last_paren = i
                            break
                if last_paren > 0:
                    return call[:last_paren] + ', &strtok_ctx' + call[last_paren:]
                return call

            new_line = re.sub(r'\bstrtok\s*\([^;]*?\)', replace_strtok_call, line)
            # strtok → strtok_s
            new_line = new_line.replace('strtok(', 'strtok_s(')
            # 万が一スペースがある場合
            new_line = re.sub(r'\bstrtok\s*\(', 'strtok_s(', new_line)
            new_lines.append(new_line)

    content = '\n'.join(new_lines)

    # --- strtok_ctx 宣言の追加 ---
    # strtok_s を呼び出す各関数の先頭に char *strtok_ctx = NULL; を追加
    if 'strtok_s(' in content and 'strtok_ctx' in content:
        lines = content.split('\n')
        result_lines = []
        brace_depth = 0
        in_func = False
        func_start_idx = -1
        decl_added_funcs = set()

        for i, line in enumerate(lines):
            result_lines.append(line)
            stripped = line.strip()

            # 関数本体の開始 (depth 0 での { )
            if stripped == '{' and brace_depth == 0:
                in_func = True
                brace_depth = 1
                func_start_idx = len(result_lines) - 1
                continue

            if in_func:
                brace_depth += line.count('{') - line.count('}')

                # 宣言領域の終わり (空行) を検出
                if stripped == '' and brace_depth == 1 and func_start_idx not in decl_added_funcs:
                    # この関数内に strtok_s があるか先読み
                    depth = 1
                    func_end = len(lines)
                    for j in range(i + 1, len(lines)):
                        depth += lines[j].count('{') - lines[j].count('}')
                        if depth <= 0:
                            func_end = j
                            break

                    func_body = '\n'.join(lines[i:func_end])
                    if 'strtok_s(' in func_body:
                        # 既に宣言がないか確認
                        decl_area = '\n'.join(lines[func_start_idx:i])
                        if 'strtok_ctx' not in decl_area:
                            indent_m = re.match(r'^(\s+)', lines[i - 1]) if i > 0 else None
                            indent = indent_m.group(1) if indent_m else '\t'
                            result_lines.insert(-1, f'{indent}char *strtok_ctx = NULL;')
                            decl_added_funcs.add(func_start_idx)

                if brace_depth <= 0:
                    in_func = False
                    brace_depth = 0

        content = '\n'.join(result_lines)

    if content != original:
        write_file(fullpath, content, enc)
        print(f'  {count} strtok replaced: {os.path.basename(filepath)}')
    else:
        print(f'  no changes: {os.path.basename(filepath)}')

    return count


if __name__ == '__main__':
    print('=== strtok → strtok_s replacement ===')
    total = 0
    for f in files:
        total += process_file(f)
    print(f'Total: {total} strtok replacements.')
