  if (*sec < 0) return(RS_ILP) ;        //�b�������Ȃ�΃p�����[�^�s��*1997.6.19
  gmtime_s(&tmt_buf, sec) ;             /*���ݎ����������v�f�ɕϊ�            */

  work.ct_year_s = tmt_buf.tm_year +1900 ; /*�N�i����4���j���Z�b�g               */
