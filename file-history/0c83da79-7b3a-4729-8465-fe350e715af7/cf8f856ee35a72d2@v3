           work.ct_year_s = work.ct_year_s - 1 ; /*�N����N�ɂ���             */
           prm_s = SS_DATE_1231_P ;     /*��N�̍ŏI�����擾                  */
           }
        }
        base.ct_year_s = work.ct_year_s ;/*�N�i����4���j���Z�b�g              */
        base.ct_mon_s = work.ct_mon_s ;  /*�����Z�b�g                         */
        base.ct_day_s = work.ct_day_s ;  /*�����Z�b�g                         */
        rtnsts_i = F_date(prm_s, &base, &base) ;
