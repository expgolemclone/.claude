# qutebrowser config.py
# autoconfig.yml は読み込まない（設定はすべてここで管理）
config.load_autoconfig(False)

# 広告ブロック
c.content.blocking.method = "both"
c.content.blocking.adblock.lists = [
    # デフォルト（EasyList）
    "https://easylist.to/easylist/easylist.txt",
    "https://easylist.to/easylist/easyprivacy.txt",
    # uBlock Origin フィルター
    "https://raw.githubusercontent.com/uBlockOrigin/uAssets/master/filters/filters.txt",
    "https://raw.githubusercontent.com/uBlockOrigin/uAssets/master/filters/privacy.txt",
    "https://raw.githubusercontent.com/uBlockOrigin/uAssets/master/filters/badware.txt",
    "https://raw.githubusercontent.com/uBlockOrigin/uAssets/master/filters/unbreak.txt",
    "https://raw.githubusercontent.com/uBlockOrigin/uAssets/master/filters/annoyances-cookies.txt",
    "https://raw.githubusercontent.com/uBlockOrigin/uAssets/master/filters/annoyances-others.txt",
    # 日本語向け（もちフィルタ）
    "https://raw.githubusercontent.com/eEIi0A5L/adblock_filter/master/mochi_filter.txt",
]

# GitHub でクリップボード貼り付けを許可
config.set("content.javascript.clipboard", "access-paste", "https://github.com")

# Gmail を mailto ハンドラに登録
config.set(
    "content.register_protocol_handler",
    True,
    "https://mail.google.com?extsrc=mailto&url=%25s",
)

# 起動ページ・デフォルトページ
c.url.start_pages = ["https://claude.ai"]
c.url.default_page = "https://claude.ai"

# 検索エンジン
c.url.searchengines = {"DEFAULT": "https://www.google.com/search?q={}"}

# Bitwarden パスワード自動入力
config.bind('<Alt-p>', 'spawn --userscript qute-bitwarden.bat')

# YouTube を mpv で再生（広告なし）
config.bind('<Alt-m>', 'spawn C:/Users/0000250059/AppData/Local/Programs/mpv.net/mpvnet.exe {url}')
