@echo off
setlocal

:: --------------------------------------------------------
:: Upload build artifacts to E:\micronet
:: Run this script from the repository root directory.
:: --------------------------------------------------------

set DEST=E:\micronet

:: Move to the repository root (same directory as this script)
cd /d %~dp0

:: Verify destination exists
if not exist "%DEST%" (
    echo ERROR: Destination "%DEST%" does not exist.
    exit /b 1
)

echo ==================================================
echo  Upload to %DEST% - Start    %date% %time%
echo ==================================================

:: bin (help files, WebView2, PdfSharp, etc.)
echo [1/6] Copying bin ...
xcopy bin "%DEST%\bin\" /S /E /K /H /V /Y

:: dll
echo [2/6] Copying dll ...
xcopy Build\Image\exe_test\dll "%DEST%\dll\" /S /E /K /H /V /Y

:: exe
echo [3/6] Copying exe ...
xcopy Build\Image\exe_test\exe "%DEST%\exe\" /S /E /K /H /V /Y

:: file
echo [4/6] Copying file ...
xcopy Build\Image\exe_test\file "%DEST%\file\" /S /E /K /H /V /Y

:: tool
echo [5/6] Copying tool ...
xcopy Build\Image\exe_test\tool "%DEST%\tool\" /S /E /K /H /V /Y

:: Web
echo [6/6] Copying Web ...
xcopy Build\Image\exe_test\Web "%DEST%\Web\" /S /E /K /H /V /Y

echo ==================================================
echo  Upload to %DEST% - End      %date% %time%
echo ==================================================

endlocal
