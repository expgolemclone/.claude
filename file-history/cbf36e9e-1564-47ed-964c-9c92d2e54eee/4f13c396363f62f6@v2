//
// ListView Sort CallBack Function
//
int CALLBACK CompareFunc(LPARAM lParam1, LPARAM lParam2, LPARAM lParamSort)
{
  const CErrorLogView::T_m_Sort* pSort = (CErrorLogView::T_m_Sort*)lParamSort;
  
  int nIndex1 = (int)LOWORD(lParam1);
  int nIndex2 = (int)LOWORD(lParam2);

  const T_erlog_data* pData1 = &g_ErrLog.Data[nIndex1];
  const T_erlog_data* pData2 = &g_ErrLog.Data[nIndex2];
  
  int nBaseComp = (int)(HIWORD(lParam1) - HIWORD(lParam2)) * pSort->nOrder[CErrorLogView::LIST_COL_DATE];

  switch (pSort->nType)
  {
  case CErrorLogView::LIST_COL_DATE:
    return nBaseComp;
    break;

  case CErrorLogView::LIST_COL_TASK:
    if (pData1->prono_s == pData2->prono_s)
      return nBaseComp;
    else
      return (int)(pData1->prono_s - pData2->prono_s) * pSort->nOrder[pSort->nType];
    break;

  case CErrorLogView::LIST_COL_TYPE:
    if (pData1->errkind_i == pData2->errkind_i)
      return nBaseComp;
    else
      return (int)(pData1->errkind_i - pData2->errkind_i) * pSort->nOrder[pSort->nType];
    break;

  case CErrorLogView::LIST_COL_ID:
    if (pData1->errorid_i == pData2->errorid_i)
      return nBaseComp;
    else
      return (int)(pData1->errorid_i - pData2->errorid_i) * pSort->nOrder[pSort->nType];
    break;

  case CErrorLogView::LIST_COL_COMMENT:
    {
      int nLength1 = (int)strlen(pData1->mess_c);            // OPS5000_64bit mod
      int nLength2 = (int)strlen(pData2->mess_c);            // OPS5000_64bit mod

      if ((nLength1 == 0) && (nLength2 == 0))
        return nBaseComp;
      else if (nLength1 == 0)
        return 1 * pSort->nOrder[pSort->nType];
      else if (nLength2 = 0)
        return -1 * pSort->nOrder[pSort->nType];

      int nComp = strcoll(pData1->mess_c, pData2->mess_c) * pSort->nOrder[pSort->nType];
      if (nComp == 0)
        return nBaseComp;
      else
        return nComp;
    }
    break;

  default:
    return 0;
  }

  return 0;
}

