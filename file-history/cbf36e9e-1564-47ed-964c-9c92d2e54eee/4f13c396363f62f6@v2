void CErrorLogView::SetMenuCheck(int nID)
{
  static const int nViewID[] =
  {
    ID_VIEW_1000, ID_VIEW_2000, ID_VIEW_3000, ID_VIEW_4000, ID_VIEW_5000,
    ID_VIEW_ALL, -1,
  };

  CMenu* pMenu = (::AfxGetMainWnd())->GetMenu();

  for (int i = 0; nViewID[i] != -1; i++)
  {
    if (nViewID[i] == nID)
      pMenu->CheckMenuItem(nViewID[i], MF_CHECKED | MF_BYCOMMAND);
    else
      pMenu->CheckMenuItem(nViewID[i], MF_UNCHECKED | MF_BYCOMMAND);
  }
}

