void CErrorLogView::OnUpdateViewStyles(CCmdUI* pCmdUI) 
{
  switch (pCmdUI->m_nID)
  {
  case ID_VIEW_1000:
    if (m_ViewType == VIEW_1000)
      SetMenuCheck(ID_VIEW_1000);
    break;
  
