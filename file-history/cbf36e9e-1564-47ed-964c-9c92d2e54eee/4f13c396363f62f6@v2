void CErrorLogView::FillListView(CListCtrl* pList)
{
  BeginWaitCursor();  
  
  // List View �f�[�^��S�č폜
  pList->DeleteAllItems();
  pList->UpdateWindow();

  pList->SetRedraw(FALSE);

  tm pTm_buf;
  LV_ITEM Item;
  char cWork[128];

  int nRec = g_ErrLog.Head.writep_i-1;

  // �G���[ ���O�S��
  for (int i = 0; i < m_ViewType; i++)
  {
    nRec--;
    if (nRec < 0)
    {
      if (g_ErrLog.Head.cycflg_i != AF_ERLOG_CYC_P)
        break;
      nRec = CNF_ERRLOG_N-1;
    }
    const T_erlog_data* pLogData = &g_ErrLog.Data[nRec];

    // ���������擾
    time_t tWork = pLogData->errtime_t + _timezone;
    localtime_s(&pTm_buf, &tWork);
    
    // �����Ȏ����̏ꍇ�͏I��
    if (pLogData->errtime_t == 0)
      break;

    if (m_tDate != -1)
    {
      switch (m_nCondition)
      {
      // �w������ȑO
      case 0:
        if (!(m_tDate >= tWork))
          continue;
        break;

      // �w������ȍ~
      case 1:
        if (!(m_tDate <= tWork))
          continue;
        break;
      }
    }

    if (m_nTaskNo != -1)
    {
      if (!(m_nTaskNo == (int)pLogData->prono_s))
        continue;
    }

    // ���t ������쐬
    strftime(cWork, sizeof(cWork), _T(" %Y/%m/%d %H:%M:%S"), &pTm_buf);

    // ���t
    memset(&Item, 0, sizeof(Item));
    Item.mask = LVIF_TEXT | LVIF_PARAM;
    Item.iItem = 0;
    Item.iSubItem = LIST_COL_DATE;
    Item.pszText = (LPSTR)cWork;
    // Item�̃f�[�^�͔z��v�f
    Item.lParam = (LPARAM)MAKELONG((WORD)nRec, (WORD)m_ViewType - i);
    pList->InsertItem(&Item);

    // �^�X�NNo.
    memset(&Item, 0, sizeof(Item));
    Item.mask = LVIF_TEXT;
    Item.iSubItem = LIST_COL_TASK;
    Item.pszText = (LPSTR)GetTaskName((int)pLogData->prono_s);
    pList->SetItem(&Item);

    // �G���[���
    sprintf(cWork, _T("0x%04x"), pLogData->errkind_i);
    memset(&Item, 0, sizeof(Item));
    Item.mask = LVIF_TEXT;
    Item.iSubItem = LIST_COL_TYPE;
    Item.pszText = (LPSTR)cWork;
    pList->SetItem(&Item);

    // �G���[ID
    sprintf(cWork, _T("0x%08x"), pLogData->errorid_i);
    memset(&Item, 0, sizeof(Item));
    Item.mask = LVIF_TEXT;
    Item.iSubItem = LIST_COL_ID;
    Item.pszText = (LPSTR)cWork;
    pList->SetItem(&Item);

    // �G���[���b�Z�[�W
    memset(&Item, 0, sizeof(Item));
    Item.mask = LVIF_TEXT;
    Item.iSubItem = LIST_COL_COMMENT;
    Item.pszText = (LPSTR)pLogData->mess_c;
    pList->SetItem(&Item);

    // ���1
    if (pLogData->prono_s == TN_AOSYSI)
      if ((pLogData->errorid_i == 0xe102) ||
          (pLogData->errorid_i == 0xf301))
        sprintf(cWork, _T("%s"), GetTaskName((int)pLogData->errinf1_i)); // OPS5000_64bit mod
      else
        sprintf(cWork, _T("%lld"), pLogData->errinf1_i);             // OPS5000_64bit mod
    else
      sprintf(cWork, _T("%lld"), pLogData->errinf1_i);               // OPS5000_64bit mod

    memset(&Item, 0, sizeof(Item));
    Item.mask = LVIF_TEXT;
    Item.iSubItem = LIST_COL_INFO1;
    Item.pszText = (LPSTR)cWork;
    pList->SetItem(&Item);

    // ���2
    if (pLogData->errkind_i == 0x130)
      sprintf(cWork, _T("%s"), GetTaskName(pLogData->errinf2_i % CNF_TASK_N));
    else
      sprintf(cWork, _T("%lld"), pLogData->errinf2_i);            // OPS5000_64bit mod
    memset(&Item, 0, sizeof(Item));
    Item.mask = LVIF_TEXT;
    Item.iSubItem = LIST_COL_INFO2;
    Item.pszText = (LPSTR)cWork;
    pList->SetItem(&Item);

    // ���3
    if (pLogData->errkind_i == 0x130)
      sprintf(cWork, _T("%s"), GetTaskName(pLogData->errinf3_i % CNF_TASK_N));
    else
      sprintf(cWork, _T("%lld"), pLogData->errinf3_i);             // OPS5000_64bit mod
    memset(&Item, 0, sizeof(Item));
    Item.mask = LVIF_TEXT;
    Item.iSubItem = LIST_COL_INFO3;
    Item.pszText = (LPSTR)cWork;
    pList->SetItem(&Item);

    // ���4
    sprintf(cWork, _T("%lld"), pLogData->errinf4_i);              // OPS5000_64bit mod
    memset(&Item, 0, sizeof(Item));
    Item.mask = LVIF_TEXT;
    Item.iSubItem = LIST_COL_INFO4;
    Item.pszText = (LPSTR)cWork;
    pList->SetItem(&Item);
  }

  // �f�[�^��ݒ肵���ꍇ�́ASort����
  if (0 != pList->GetItemCount())
  {
    pList->SortItems(CompareFunc, (DWORD_PTR)&m_Sort);        // OPS5000_64bit mod
  }

  pList->SetRedraw();
  pList->UpdateWindow();

  EndWaitCursor();  
}

