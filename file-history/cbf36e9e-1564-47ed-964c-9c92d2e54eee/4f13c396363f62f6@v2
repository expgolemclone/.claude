void CErrorLogView::DrawItem(LPDRAWITEMSTRUCT lpDrawItemStruct)
{
  CListCtrl& list = GetListCtrl();

  // �f�B�o�C�X�R���e�L�X�g �擾
  CDC* pDC = CDC::FromHandle(lpDrawItemStruct->hDC);

  // �`�悷��A�C�e���̍��W �擾
  CRect rcDrawItem(lpDrawItemStruct->rcItem);

  // �A�C�e�� �C���f�b�N�X�i�s�j�擾
  int nItem = lpDrawItemStruct->itemID;

  // �t�H�[�J�X �m�F
  BOOL bFocus = FALSE;
  if (GetFocus() == this)
    bFocus = TRUE;

  // �A�C�e���f�[�^ �擾
  LV_ITEM Item;
  memset(&Item, 0 ,sizeof(Item));
  Item.mask = LVIF_TEXT | LVIF_IMAGE | LVIF_STATE | LVIF_PARAM;
  Item.iItem = nItem;
  Item.iSubItem = 0;
  Item.stateMask = 0xFFFF;
  list.GetItem(&Item);

  // �A�C�e���̑I����� �m�F
  BOOL bSelected = FALSE;
  if ((bFocus) || (GetStyle() & LVS_SHOWSELALWAYS))
  {
    if (Item.state & LVIS_SELECTED)
      bSelected = TRUE;
  }
  
  // �A�C�e���\���� �擾
  CRect rcItem;
  list.GetItemRect(nItem, rcItem, LVIR_BOUNDS);

  // �A�C�e�� ���x���\���� �擾
  CRect rcItemLabel;
  list.GetItemRect(nItem, rcItemLabel, LVIR_LABEL);

  // ���ʒu�����x���ʒu�ɑ�����
  rcItem.left = rcItemLabel.left;

  // ������ �擾
  CString strText = list.GetItemText(nItem, 0);
  CSize szChar = pDC->GetTextExtent(strText);

  // �I����ԐF �擾
  COLORREF clrSelText = ::GetSysColor(COLOR_HIGHLIGHTTEXT);
  COLORREF clrSelTextBk = ::GetSysColor(COLOR_HIGHLIGHT);

  // �e�L�X�g�\���F �擾
  int nIndex = (int)LOWORD(Item.lParam);
  COLORREF clrText;
  const T_erlog_data* pData = &g_ErrLog.Data[nIndex];
  
  switch (pData->prono_s)
  {
  case TN_AOSYSI:
  case TN_AOUPSER:
//  case TN_JOFLNET:
//  case TN_AOLOGOFF:
    clrText = RGB(255, 0, 0);
    break;
  
//  case TN_AOLOGOFF:
//    clrText = RGB(0, 128, 0);
//    break;
  
  default:
    clrText = RGB(0, 0, 0);
    break;
  }
  
  COLORREF clrTextBk = RGB(255, 255, 255);

  // 1�s�I����� �擾
  BOOL bFullRow = list.GetExtendedStyle() & LVS_EX_FULLROWSELECT;

  // 1�s�I���̏ꍇ�͍s�S�̂�h��Ԃ�
  if (bFullRow)
  {
    if (bSelected)
      pDC->FillRect(&rcItem, &CBrush(clrSelTextBk));
    else
      pDC->FillRect(&rcItem, &CBrush(clrTextBk));
  }
  // ���̑��͍ŏ��̃��x���͈̔͂���
  else
  {
    if (bSelected)
      pDC->FillRect(&rcItemLabel, &CBrush(clrSelTextBk));
    else
      pDC->FillRect(&rcItemLabel, &CBrush(clrTextBk));
  }
  
  // �I����Ԃ̏ꍇ�͑I��F�ɂ���
  if (bSelected)
  {
    pDC->SetTextColor(clrSelText);
  }
  else
  {
    pDC->SetTextColor(clrText);
  }
  // ���x����`��
  pDC->DrawText(strText, &rcItemLabel, DT_END_ELLIPSIS | DT_EXPANDTABS | DT_LEFT | DT_NOCLIP | DT_SINGLELINE  | DT_VCENTER);
  
  LV_COLUMN Column;
  memset(&Column, 0, sizeof(Column));
  Column.mask = LVCF_FMT | LVCF_WIDTH;

  for (int i  = 1; list.GetColumn(i, &Column); i++)
  {
    // �T�u �A�C�e���̕\���̈� �擾
    CRect rcSubLabel;
    list.GetSubItemRect(nItem, i, LVIR_LABEL, rcSubLabel);
    rcSubLabel.left += 4;
    rcSubLabel.right -= 4;
    
    // �T�u�A�C�e���̕�������擾
    CString strText = list.GetItemText(nItem, i);

    // 1�s�I���̏ꍇ�͍s�S�̂�I��F�ɂ���
    if ((bSelected) && (bFullRow))
      pDC->SetTextColor(clrSelText);
    else
      pDC->SetTextColor(clrText);

    // �T�u�A�C�e����`��
    UINT nFormat = DT_LEFT;
    if (Column.fmt & LVCFMT_RIGHT)
      nFormat = DT_RIGHT;
    else if (Column.fmt & LVCFMT_CENTER)
      nFormat = DT_CENTER;

    if (nFormat = DT_RIGHT)
    {
      for (int j = 0; j < strText.GetLength(); j++)
      {
        TCHAR cWork = strText.GetAt(j);
        
        // �擪�̕����� x,X,- �͐����Ɣ��f����
        if (j == 0)
        {
          switch (cWork)
          {
          case 'x':
          case 'X':
          case '-':
            continue;
            break;
          }
        }

        // 10,16�i�����ȊO�͕�����Ƃ���
        if (!(iswxdigit((int)cWork)))
        {
          nFormat = DT_LEFT;
          break;
        }
      }
    }

    pDC->DrawText(strText, &rcSubLabel, nFormat | DT_END_ELLIPSIS | DT_EXPANDTABS | DT_NOCLIP | DT_SINGLELINE | DT_VCENTER);
  }
}

