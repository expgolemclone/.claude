# coding: cp932
"""pre-commit hook: пїЅXпїЅeпїЅ[пїЅWпїЅП‚ЭѓtпїЅ@пїЅCпїЅпїЅпїЅпїЅ CP932 + CRLF пїЅЙ•ПЉпїЅпїЅпїЅпїЅпїЅ."""

import os
import shutil
import subprocess
import sys
import tempfile


def staged_files():
    """git diff --cached пїЅЕ’З‰пїЅ/пїЅПЌXпїЅпїЅпїЅк‚ЅпїЅtпїЅ@пїЅCпїЅпїЅпїЅpпїЅXпїЅпїЅФ‚пїЅ."""
    result = subprocess.run(
        ["git", "diff", "--cached", "--diff-filter=ACMR", "--name-only", "-z"],
        capture_output=True,
    )
    if result.returncode != 0:
        raise RuntimeError(f"git diff failed: {result.stderr.decode()}")
    raw = result.stdout
    if not raw:
        return []
    # -z: null пїЅпїЅШ‚пїЅ (пїЅпїЅпїЅпїЅпїЅМ‹пїЅvпїЅfпїЅпїЅпїЅпїЅпїЅO)
    return [p for p in raw.decode("utf-8").split("\0") if p]


def detect_encoding(data: bytes) -> str | None:
    """пїЅGпїЅпїЅпїЅRпїЅ[пїЅfпїЅBпїЅпїЅпїЅOпїЅпїЅпїЅпїЅпїЅSпїЅЙЊпїЅпїЅoпїЅпїЅпїЅпїЅ.

    Returns:
        "utf-16-le" / "utf-16-be" / "utf-8-sig" / "ascii" / "utf-8" / "cp932" / "shift_jis"
        пїЅпїЅпїЅoпїЅsпїЅ\пїЅИ‚пїЅ None
    """
    # 1. UTF-16 BOM
    if data[:2] == b"\xff\xfe":
        return "utf-16-le"
    if data[:2] == b"\xfe\xff":
        return "utf-16-be"

    # 2. null byte пїЅпїЅ пїЅoпїЅCпїЅiпїЅпїЅ (пїЅж“Є 512 byte)
    if b"\x00" in data[:512]:
        return None  # пїЅoпїЅCпїЅiпїЅпїЅпїЅпїЅпїЅпїЅ

    # 3. UTF-8 BOM
    if data[:3] == b"\xef\xbb\xbf":
        return "utf-8-sig"

    # 4. пїЅпїЅ ASCII
    if all(b < 0x80 for b in data):
        return "ascii"

    # 5. UTF-8 strict
    try:
        data.decode("utf-8", errors="strict")
        return "utf-8"
    except UnicodeDecodeError:
        pass

    # 6. CP932 strict
    try:
        data.decode("cp932", errors="strict")
        return "cp932"
    except UnicodeDecodeError:
        pass

    # 7. Shift-JIS strict (CP932 пїЅЖ”пїЅпїЅпїЅпїЅЙѓ}пїЅbпїЅsпїЅпїЅпїЅOпїЅпїЅпїЅЩ‚И‚пїЅ)
    try:
        data.decode("shift_jis", errors="strict")
        return "shift_jis"
    except UnicodeDecodeError:
        pass

    return None


def normalize_newlines(text: str) -> str:
    """пїЅпїЅпїЅsпїЅпїЅ CRLF пїЅЙђпїЅпїЅKпїЅпїЅпїЅпїЅпїЅпїЅ.

    CRLF пїЅпїЅ LF пїЅпїЅ CR пїЅпїЅ LF пїЅМЏпїЅпїЅЙ“пїЅпїЅк‚µпїЅAпїЅЕЊпїЅпїЅ LF пїЅпїЅ CRLF пїЅЙ‚пїЅпїЅпїЅ.
    """
    text = text.replace("\r\n", "\n")
    text = text.replace("\r", "\n")
    text = text.replace("\n", "\r\n")
    return text


def is_cp932_crlf(data: bytes) -> bool:
    """пїЅпїЅпїЅпїЅ CP932 + CRLF пїЅпїЅпїЅЗ‚пїЅпїЅпїЅпїЅр”»’и‚·пїЅпїЅ."""
    # CP932 пїЅЖ‚пїЅпїЅДѓfпїЅRпїЅ[пїЅhпїЅЕ‚пїЅпїЅй‚©
    try:
        data.decode("cp932", errors="strict")
    except UnicodeDecodeError:
        return False

    # bare LF (CRLF пїЅЕ‚И‚пїЅ LF) пїЅпїЅ bare CR пїЅпїЅпїЅИ‚пїЅпїЅпїЅ
    i = 0
    while i < len(data):
        if data[i] == 0x0A:  # LF
            if i == 0 or data[i - 1] != 0x0D:  # bare LF
                return False
        elif data[i] == 0x0D:  # CR
            if i + 1 >= len(data) or data[i + 1] != 0x0A:  # bare CR
                return False
        i += 1
    return True


def convert_file(filepath: str) -> bool:
    """пїЅtпїЅ@пїЅCпїЅпїЅпїЅпїЅ CP932 + CRLF пїЅЙ•ПЉпїЅпїЅпїЅпїЅпїЅ.

    Returns:
        True: пїЅпїЅпїЅпїЅ (пїЅПЉпїЅпїЅП‚пїЅ or пїЅXпїЅLпїЅbпїЅv), False: пїЅGпїЅпїЅпїЅ[
    """
    data = open(filepath, "rb").read()

    if not data:
        return True  # пїЅпїЅtпїЅ@пїЅCпїЅпїЅпїЅНѓXпїЅLпїЅbпїЅv

    # пїЅпїЅпїЅпїЅ CP932 + CRLF пїЅИ‚пїЅXпїЅLпїЅbпїЅv
    if is_cp932_crlf(data):
        return True

    enc = detect_encoding(data)

    if enc is None:
        # null byte пїЅпїЅпїЅпїЅпїЅпїЅпїЅпїЅпїЅкЌ‡пїЅНѓoпїЅCпїЅiпїЅпїЅ пїЅпїЅ пїЅXпїЅLпїЅbпїЅv
        if b"\x00" in data[:512]:
            return True
        # пїЅпїЅпїЅoпїЅsпїЅ\
        print(f"ERROR: encoding detection failed: {filepath}", file=sys.stderr)
        return False

    # ASCII пїЅпїЅ CP932 пїЅЭЉпїЅпїЅИ‚М‚Е‰пїЅпїЅsпїЅпїЅпїЅпїЅпїЅпїЅпїЅKпїЅпїЅ
    if enc == "ascii":
        text = data.decode("ascii")
    elif enc == "utf-16-le":
        text = data.decode("utf-16-le")
    elif enc == "utf-16-be":
        text = data.decode("utf-16-be")
    elif enc == "utf-8-sig":
        text = data.decode("utf-8-sig")
    elif enc == "utf-8":
        text = data.decode("utf-8")
    elif enc == "cp932":
        text = data.decode("cp932")
    elif enc == "shift_jis":
        text = data.decode("shift_jis")
    else:
        print(f"ERROR: unexpected encoding '{enc}': {filepath}", file=sys.stderr)
        return False

    # CRLF пїЅпїЅпїЅKпїЅпїЅ
    text = normalize_newlines(text)

    # CP932 пїЅGпїЅпїЅпїЅRпїЅ[пїЅh (strict)
    try:
        new_data = text.encode("cp932", errors="strict")
    except UnicodeEncodeError as e:
        print(
            f"ERROR: cannot encode to CP932: {filepath}: {e}",
            file=sys.stderr,
        )
        return False

    # пїЅПЉпїЅпїЅгЊџпїЅпїЅ: CP932 strict decode + bare LF/CR пїЅИ‚пїЅ
    try:
        new_data.decode("cp932", errors="strict")
    except UnicodeDecodeError:
        print(
            f"ERROR: post-conversion CP932 verification failed: {filepath}",
            file=sys.stderr,
        )
        return False

    if not is_cp932_crlf(new_data):
        print(
            f"ERROR: post-conversion CRLF verification failed: {filepath}",
            file=sys.stderr,
        )
        return False

    # atomic write
    dirpath = os.path.dirname(os.path.abspath(filepath))
    fd, tmp_path = tempfile.mkstemp(dir=dirpath)
    closed = False
    try:
        os.write(fd, new_data)
        os.close(fd)
        closed = True
        shutil.move(tmp_path, filepath)
    except Exception:
        if not closed:
            os.close(fd)
        if os.path.exists(tmp_path):
            os.remove(tmp_path)
        raise

    # пїЅДѓXпїЅeпїЅ[пїЅW
    subprocess.run(["git", "add", filepath], check=True)
    print(f"  converted ({enc} -> cp932+crlf): {filepath}")
    return True


def main() -> int:
    files = staged_files()
    if not files:
        print("  no staged files.")
        return 0

    errors = []
    for f in files:
        if not os.path.isfile(f):
            continue
        # .vscode/ пїЅzпїЅпїЅпїЅпїЅ UTF-8 пїЅKпїЅ{пїЅМ‚пїЅпїЅЯ•ПЉпїЅпїЅОЏЫЉO
        if f.replace("\\", "/").startswith(".vscode/"):
            continue
        if not convert_file(f):
            errors.append(f)

    if errors:
        print(
            f"\nERROR: {len(errors)} file(s) failed encoding conversion:",
            file=sys.stderr,
        )
        for e in errors:
            print(f"  {e}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
