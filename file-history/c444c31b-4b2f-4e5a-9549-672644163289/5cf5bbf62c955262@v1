//------------------------------------------------------------------------------
//	プロセス内シンボル
//------------------------------------------------------------------------------
#define S_TAG		0x80						//コマンド タグ情報
#define S_MAN		0x82						//コマンド マンマシン情報
#define S_PAR		4							//ファンクションＭＰＢ部分情報
#define S_ALL		6							//ファンクションＭＰＢ全情報
#define S_ADC		0							//ファンクション ＡＤＣ用
#define S_HSZ		32							//伝送ヘッダ byte size
#define S_PSZ		64							//１部分情報データbyte size
#define S_ASZ		260							//１全情報データbyte size
#define S_MSZ		16							//マンマシンヘッダ byte size

//------------------------------------------------------------------------------
//	関数プロトタイプ宣言部
//------------------------------------------------------------------------------
int		f_11rv100();							//１：１伝送受信初期処理
void	f_11rv200( union U_ONE_BUF* );			//ＭＰＢ部分データ受信時処理
BOOL	f_11rv210( short*, short*, short* );	//ＭＰＢ部分情報受信データ正当性判定処理
void	f_11rv300( union U_ONE_BUF* );			//ＭＰＢ全データ受信時処理
BOOL	f_11rv310( short*, short*, short* );	//ＭＰＢ全情報受信データ正当性判定処理
void	f_11rv400( union U_ONE_BUF* );			//マンマシンコマンドデータ受信時処理


//------------------------------------------------------------------------------
//	プロセス内コモンエリア
//------------------------------------------------------------------------------
HANDLE						z_hAda;				//ＡＤＡデバイスハンドル
struct ada4k_transferEx*	z_pOne;				//１：１伝送受信バッファポインタ
struct Q_T_GPCSM_MAN        z_cmdAns;	        //マンマシン応答通知送信バッファ

//------------------------------------------------------------------------------
//	メイン処理
//------------------------------------------------------------------------------
void main()
{
	int					Rsts_i;					//リターンステータス
	unsigned int		bp_ui;					//受信バッファポイント格納
	DWORD				dwBufSize;				//Ｒ／Ｗバッファサイズ
	DWORD				dwRcvSize;				//出力の実際のバイト数
	DWORD				dwErrNo;				//
	union U_ONE_BUF*	pOneBuf;				//１：１受信データバッファポインタ

	//--------------------------------------------------------------------------
	//１：１伝送受信初期化処理を実施、失敗時はプロセス停止
	//--------------------------------------------------------------------------
	Rsts_i = f_11rv100();
	if (0 != Rsts_i) exit(0);

	//--------------------------------------------------------------------------
	//以下を永久ループで１：１伝送受信で受信したデータに対応した処理を実施
	//--------------------------------------------------------------------------
	while (TRUE) {

		//自ノード異常の間はここでループ
		while (MU_pnet->mod_ui == MU_PNET_PERR_P) {
			D( DP2_("MO11RD 自ノード異常中により睡眠中\n"); )
			(void)Sleep(MF_pnet->wait_ui*1000);			//指定時間中断
		}

		//受信バッファはトレース中
		if (MU_pnet->opnt_ui <= (CNF_TRBUF_N-2)) {
			++MU_pnet->opnt_ui;						//次の受信バッファを指定
		}											//受信バッファはトレース開始
		else if(MU_pnet->opnt_ui != (CNF_TRBUF_N-1)) {
			MU_pnet->opnt_ui = 0;					//  トレース先頭バッファを指定
		}											//上記以外は最終面

		bp_ui = MU_pnet->opnt_ui;					//受信バッファポイントセット

		//受信バッファセット
		z_pOne = &MU_pnet->obf[bp_ui];

		//----------------------------------------------------------------------
		//１：１伝送データ受信待ち
		//	なんらかのデータを受信するまでこのライブラリ内で待ち状態になります。
		//----------------------------------------------------------------------
		dwBufSize = sizeof(struct ada4k_transferEx);
		dwRcvSize = 0;
		Rsts_i = DeviceIoControl( z_hAda, IOCTL_ADA4K_RECEIVE, z_pOne, dwBufSize,
								  z_pOne, dwBufSize, &dwRcvSize, NULL );
		if (0 == Rsts_i) {

			dwErrNo = GetLastError();

			//エラーログ登録
			F_errlog(0x0150, 0x0001, dwErrNo, 0, 0, 0, "１：１受信エラー(INF1:err)");

			//自ノード異常
			if ((ERROR_NETWORK_ACCESS_DENIED == dwErrNo) ||	//Ｆ／Ｗが動作していません もしくは
				(ERROR_NOT_READY             == dwErrNo)) {	//実行不能です

				//データ上では正常(初回の異常検地の場合)
				if (MU_pnet->mod_ui == MU_PNET_PNOR_P) {
					//入出力監視へP-NET初期化要求を実施（メモリ要求）
					//	P-NET(ADA)運用データの要求マスク情報にP-NET初期化要求ビット(要因:ノード異常)を設定
					MU_pnet->reqflg_ui[MU_PNET_INI_P] = SS_ON_P;
				}
				(void)Sleep(MF_pnet->wait_ui*1000);			//指定時間中断
				continue;									//永久繰り返し処理へ
			}
			//Ｉ／Ｏタイムアウト
			else if (ERROR_SEM_TIMEOUT == dwErrNo) {
				continue;									//永久繰り返し処理へ
			}
			//待ち中にADA初期化された時に発生するエラーコード
			else if (ERROR_OPERATION_ABORTED == dwErrNo) {
				continue;									//永久繰り返し処理へ
			}
			//上記以外（システム異常）
			else {
				Rsts_i = CloseHandle(z_hAda);				//P-NETをクローズする
				exit(0);									//プロセス終了
			}
		}

		//Ｆ／Ｗステータスが正常値以外の場合	YS080617
		if (0x0001 != z_pOne->transfer.fwstatus) {
			F_errlog( 0x0150, 0x0007, z_pOne->transfer.fwstatus, 0, 0, 0,
				  "Ｆ／Ｗステータス異常(INF1:FwSts)" );
			//ログ記録は行うが、従来この処理ではＦＷステータスチェックはしていないため
			//	処理はとりあえずこのまま継続させる。
		}

        //自装置回線種別がADA4000無効なら
        if (!(JD_wstn[AF_sys->ownn_s - 1].pnetknd_us & PNET_KIND_ADA4_N))
            continue;                                       //永久繰り返し処理へ

		//ステーション番号逸脱
		if ((z_pOne->transfer.nodenum < 1) || (z_pOne->transfer.nodenum > CNF_MAX_ADAPCS_N)) {
			F_errlog( 0x1000, 0x0003, z_pOne->transfer.nodenum, 0, 0, 0,
					  "受信ステーション番号不正(INF1:Node)" );
			continue;										//永久繰り返し処理へ
		}

		//ステーション未接続
		if (SS_ENTRY_P != JD_loc[z_pOne->transfer.nodenum-1].inf_us) {
			F_errlog( 0x1000, 0x0004, z_pOne->transfer.nodenum, 0, 0, 0,
					  "ステーション未実装(INF1:Node)" );
			continue;										//永久繰り返し処理へ
		}

		//ステーション伝送不可能 もしくは 監視不可能
		if ((MU_stn[z_pOne->transfer.nodenum].mod_ui == MU_STN_OLD_P) ||
			(MU_stn[z_pOne->transfer.nodenum].mod_ui == MU_STN_DOWN_P)) {
			continue;										//永久繰り返し処理へ
		}

		//データ受信サイズ不正
		if ((z_pOne->transfer.datalen < 2) || (z_pOne->transfer.datalen > 4096)) {
			F_errlog( 0x1000, 0x0005, z_pOne->transfer.nodenum, z_pOne->transfer.datalen, 0, 0,
					  "受信データサイズ不正(INF1:Node,INF2:Size)" );
			continue;										//永久繰り返し処理へ
		}

        //自装置動作モードがマスタ(等価中)，サブ，試験以外の場合は次処理へcontinue
        if ((AU_MAS_P != AU_sys->smod_s) && 
            (AU_MASE_P != AU_sys->smod_s) &&
            (AU_SUB_P != AU_sys->smod_s) &&
            (AU_TST_P != AU_sys->smod_s)) continue;

		//----------------------------------------------------------------------
		//	受信コマンドに対応した処理を実施
		//----------------------------------------------------------------------
		pOneBuf = (union U_ONE_BUF*)&z_pOne->buf[0];

		//ＭＰＢ部分データ受信	------------------------------------------------
		if ((pOneBuf->ohd.com_uc == S_TAG) &&
			(pOneBuf->ohd.fnc_uc == S_PAR)){
			//ＭＰＢ部分データ受信時処理
			f_11rv200( pOneBuf );
		}
		else if ((pOneBuf->ohd.com_uc == S_TAG ) &&
				 (pOneBuf->ohd.fnc_uc == 0x0084)) {
			//相手先ＰＣＳが停止モード等の時にＭＰＢ部分情報要求を実施すると
			//　この応答コードで戻るようです。このパターンは簡単に起こせるものであり
			//	この状態の時にエラーログを記録するのも無駄なので排除します。
		}
		//ＭＰＢ全データ処理	------------------------------------------------
		else if((pOneBuf->ohd.com_uc == S_TAG) &&
				  (pOneBuf->ohd.fnc_uc == S_ALL)) {
			//ＭＰＢ全データ受信時処理
			f_11rv300( pOneBuf );
		}
		//マンマシン データ処理	------------------------------------------------
		else if((pOneBuf->mhd.com_uc == S_MAN) &&
				  (pOneBuf->mhd.fnc_uc == S_ADC)) {
			//マンマシンコマンド応答データ受信時処理
			f_11rv400( pOneBuf );
		}
		//未定義 データ処理	----------------------------------------------------
		else {
			F_errlog( 0x1000, 0x0006, z_pOne->transfer.nodenum, pOneBuf->ohd.com_uc,
					  pOneBuf->ohd.fnc_uc, 0,
					  "未定義データ受信(INF1:Node,INF2:CMD,INF3:FNC)" );
		}
	}
}

//------------------------------------------------------------------------------
//	１：１伝送受信初期処理
//------------------------------------------------------------------------------
int	f_11rv100()
{
	//プロセス標準初期処理
	F_init(TN_MO11RV, 0, 0);
	
	
	//初期化中フラグを落とす
	AU_task[TN_MO11RV].prf_i &= (~AU_INIT_P);
	
	//自装置の回線種別がADA4000無効?
    while (!(JD_wstn[AF_sys->ownn_s - 1].pnetknd_us & PNET_KIND_ADA4_N)) {
	   Sleep(1000);
    }


	//P-NETをオープンする
	z_hAda = CreateFile( "\\\\.\\ADA4K0",
						 GENERIC_READ | GENERIC_WRITE,
						 FILE_SHARE_READ | FILE_SHARE_WRITE,
						 NULL,
						 OPEN_EXISTING,
						 FILE_ATTRIBUTE_NORMAL,
						 NULL );
	if (INVALID_HANDLE_VALUE == z_hAda) {
		F_errlog(0x0150, 0x1001, GetLastError(), 0, 0, 0, "P-NET(ADA) OPEN ERR");
		return -1;
	}
	return 0;
}

//------------------------------------------------------------------------------
//ＭＰＢ部分データ受信時処理
//------------------------------------------------------------------------------
void f_11rv200(union U_ONE_BUF* pOneBuf)
{
	BOOL				bChgDat;		//変更データフラグ(変更なし:FALSE/変更あり:TRUE)
	BOOL				bRsts;			//リターンステータス
	int					Rsts_i;			//リターンステータス
	int					Size_i;			//サイズ
	int					i, j;			//カウンタ
	unsigned short		TagNum_us;		//タグ数
	short				Sid_s;			//ステーションＩＤ
	short				Pid_s;			//プロセスＩＤ
	struct Q_T_HEAD		qh;				//ＱＵＥヘッダー

	//タグ数をタグ数格納エリアへ
	TagNum_us = pOneBuf->ohd.num_us ;
	if ((z_pOne->transfer.datalen - S_HSZ) / S_PSZ	!= TagNum_us) {	//受信データ数不正
		F_errlog( 0x1000, 0x2001, z_pOne->transfer.nodenum, z_pOne->transfer.datalen, TagNum_us, 0,
				  "受信データ数不正(INF1:Node,INF2:Size,INF3:TagNum)" );
		return;
	}

	//受信データを対応するＭＰＢエリアへ展開する。
	bChgDat = FALSE;
	for (i=0; i<TagNum_us; i++) {

		//タグ単位のデータ項目正当性判定処理を実施
		bRsts = f_11rv210( (short*)&pOneBuf->byte_uc[32+i*64], &Sid_s, &Pid_s );
		if (!bRsts) continue;

		//データ設定対照となるＭＰＢ部分情報の面を検索
		//	１箇所とは限らないので最後までチェックする必要があります。
		for (j=1; j<=CNF_MPB_PAR_N;j++) {

			//MPB部分情報要求運用データのSID,PIDが一致し、かつクリア指定値がＯＮで無い事
			//	クリア指定値がＯＮの場合は未だ要求運用データの設定値を送信側が内部取込み
			//	していないのでこの段階では展開しない。
			if ((Sid_s == JU_plpmpbs[j].pmpb_s[0]) &&
				(Pid_s == JU_plpmpbs[j].pmpb_s[1]) ) {
				memcpy((unsigned char *)&JU_plpmpb[j].pmpb_s[JU_MPB_ST_P],
               (unsigned char *)&pOneBuf->byte_uc[32+i*64],
		       sizeof(struct T_JU_plpmpb)) ;
												  /*      PCS番号と           */
												  /*      計器番号をｾｯﾄ       */
				JU_plpmpb[j].pmpb_s[JU_MPB_ST_P] = Sid_s - 1;
				JU_plpmpb[j].pmpb_s[JU_MPB_ID_P] = Pid_s - 1;
		//                                                                            OPS5k▼
		        if ((j >= SYS_MPB_OFSET_P) &&             /*  任意用エリア内なら      */
		            (j <= SYS_MPB_OFSET_END_P))           /*  有効データフラグセット  */
		          JU_plpmpbs[j].sts_s |= JU_PLPMPBS_REPLY_P ;
          
				bChgDat = TRUE;
			}
		}
	}

	//--------------------------------------------------------------------------
	//	高速計測へデータ更新通知を送信
	//--------------------------------------------------------------------------
	if (bChgDat) {
		memset( &qh, 0, sizeof(qh) );
		qh.func_s = QF_BMESH_CHG_P;			//データ更新通知
		qh.sfnc_s = QL_BMESH_PART_P;		//部分情報
		Size_i	  = sizeof(qh);
		Rsts_i = F_quemgr ( (int)QUE_ENQ_P | QUE_NOWAIT_P,
		                    (short)Q_BMESH_KEY1,
		                    &qh,
		                    &Size_i );
		if (RS_SUC != Rsts_i) {
			F_errlog( 0x0131, 0x2002, Rsts_i, 0, 0, 0,
					  "データ変更通知(部分情報)失敗(INF1:Stat)" );
		}
	}
}

//------------------------------------------------------------------------------
//ＭＰＢ部分情報データ判定処理
//------------------------------------------------------------------------------
BOOL	f_11rv210( short* pMpbp, short* pSid_s, short* pPid_s )
{
	short			Sid_s;				//ステーションＩＤ
	short			Pid_s;				//物理ＩＤ
	short			PcsIdx_s;			//PCSインデックス

	Sid_s = pMpbp[JU_MPB_ST_P];			//ステーションＩＤ
	Pid_s = pMpbp[JU_MPB_ID_P];			//計器分類＋物理ＩＤ

	//ステーションＩＤ範囲チェック
	if ((1 > Sid_s) || (CNF_MAX_ADAPCS_N < Sid_s)) return FALSE;

	//計器分類チェック（計装でない場合はエラー）
	if ((Pid_s & 0xF000) != 0x1000) return FALSE;

	//計器分類部を除外する。
	Pid_s = (Pid_s & 0x0FFF) + 1;

	PcsIdx_s = Sid_s - 1;

	//ＰＣＳ実装チェック 未実装の場合はエラー
	if (SS_ENTRY_P != JD_loc[PcsIdx_s].inf_us)		return FALSE;

	//回線種別がADA4000でない場合はエラー
	if (JD_NET_ADA_P != JD_loc[PcsIdx_s].netknd_us)	return FALSE;

    //ノード種別がVPCSの場合はエラー
    if ((JD_STN_VPCS_P == JD_loc[PcsIdx_s].nodes_us) ||
       (JD_STN_VPCS_2_P == JD_loc[PcsIdx_s].nodes_us)) return FALSE;
	
	//ＰＣＳ種別がサポート外の場合はエラー(ADC4000,ADC5000,VC5000, VC100)
	if ((JD_loc[PcsIdx_s].tyopcs_us != JD_A4K_P  ) &&
		(JD_loc[PcsIdx_s].tyopcs_us != JD_A5K_P  ) &&
		(JD_loc[PcsIdx_s].tyopcs_us != JD_RC5_P))	return FALSE;

	//最大物理ＩＤチック
	if (JD_loc[PcsIdx_s].skiki_us >= CNF_KEIKI_N) return FALSE;

	//物理ＩＤ範囲チェック
	if ((1 > Pid_s) || ((JD_loc[PcsIdx_s].skiki_us + 1) < Pid_s)) return FALSE;

	//下記の２つはやろうかとも思ったのですが、P-NET(Ethernet)側が
	//	やってないようなのではずしています。
		//監視グループ外
		//ＰＣＳロック

	*pSid_s = Sid_s;
	*pPid_s = Pid_s;

	return TRUE;
}

//------------------------------------------------------------------------------
//ＭＰＢ全データ受信時処理
//------------------------------------------------------------------------------
void f_11rv300(union U_ONE_BUF* pOneBuf)
{
    int			bChgDat;	//変更データフラグ(変更なし:FALSE/変更あり:TRUE)
    int			bRsts;		//リターンステータス
    int			Rsts_i;		//リターンステータス
    int			Size_i;     //サイズ
    int			i, j;		//カウンタ
    unsigned short	TagNum_us;	//タグ数
    short		Sid_s;		//ステーションＩＤ
    short		Pid_s;		//プロセスＩＤ
    struct Q_T_HEAD	qh;		//ＱＵＥヘッダー

    D( DP1_("MO11RV ＭＰＢ全データ受信\n"); )

        //タグ数をタグ数格納エリアへ
        TagNum_us = pOneBuf->ohd.num_us ;
    if ((z_pOne->transfer.datalen - S_HSZ) / S_ASZ != TagNum_us) { //受信データ数不正

        F_errlog( 0x1000, 0x3001, z_pOne->transfer.nodenum, z_pOne->transfer.datalen, TagNum_us, 0,
            "受信データ数不正(INF1:Node,INF2:Size,INF3:TagNum)");
        return;
    }

    //受信データを対応するＭＰＢエリアへ展開する。
    bChgDat = SS_FALSE_P;
    for (i=0; i<TagNum_us; i++) {

        //タグ単位のデータ項目正当性判定処理を実施
        bRsts = f_11rv310( (short*)&pOneBuf->byte_uc[S_HSZ+i*S_ASZ], &Sid_s, &Pid_s );
        if (!bRsts) continue;

        //データ設定対照となるＭＰＢ部分情報の面を検索
        //  １箇所とは限らないので最後までチェックする必要があります。
        for (j=1; j<=CNF_MPB_ALL_N;j++) {

            //MPB全情報要求運用データのSID,PIDが一致し、かつクリア指定値がＯＮで無い事
            //	クリア指定値がＯＮの場合は未だ要求運用データの設定値を送信側が内部取込み
            //	していないのでこの段階では展開しない。
            if ((Sid_s == JU_plampbs[j].ampb_s[0]) &&
                (Pid_s == JU_plampbs[j].ampb_s[1])) {
                    memcpy((unsigned char *)&JU_plampb[j].ampb_s[0],
                        (unsigned char *)&pOneBuf->byte_uc[S_HSZ+i*S_ASZ],
                        S_ASZ ) ;
                    JU_plampb[j].ampb_s[0] = Sid_s - 1;          /*      PCSﾌﾞﾛｯｸ番号ｾｯﾄ      */
                    JU_plampb[j].ampb_s[1] = Pid_s - 1;          /*      換算後計器番号ｾｯﾄ    */

                    bChgDat = SS_TRUE_P;
            }
        }
    }

    //--------------------------------------------------------------------------
    //	高速計測へデータ更新通知を送信
    //--------------------------------------------------------------------------
    if (bChgDat) {
        memset( &qh, 0, sizeof(struct Q_T_HEAD) );
        qh.func_s = QF_BMESH_CHG_P;	//データ更新通知
        qh.sfnc_s = QL_BMESH_ALL_P;	//全情報
        Size_i = sizeof(struct Q_T_HEAD);
        Rsts_i = F_quemgr ( QUE_ENQ_P | QUE_NOWAIT_P,
            (short)Q_BMESH_KEY1, &qh, &Size_i );
        if (RS_SUC != Rsts_i) {
            F_errlog( 0x0131, 0x3002, Rsts_i, 0, 0, 0,
                "データ変更通知(全情報)失敗(INF1:Stat)");
        }
    }
}

//------------------------------------------------------------------------------
//ＭＰＢ全情報データ判定処理
//------------------------------------------------------------------------------
int	f_11rv310( short* pMpba, short* pSid_s, short* pPid_s )
{
    short	    Sid_s;		//ステーションＩＤ
    short	    Pid_s;		//物理ＩＤ
    short	    PcsIdx_s;		//PCSインデックス

    D( DP1_("MO11RV ＭＰＢ全情報データ判定処理\n"); )

    Sid_s = pMpba[0];			//ステーションＩＤ
    Pid_s = pMpba[1];			//計器分類＋物理ＩＤ

    //ステーションＩＤ範囲チェック
    if ((1 > Sid_s) || (CNF_MAX_ADAPCS_N < Sid_s)) return SS_FALSE_P;

    //計器分類チェック（計装でない場合はエラー）
    if ((Pid_s & 0xF000) != 0x1000) return SS_FALSE_P;
//  if ((Pid_s & 0x2000) != 0) return SS_FALSE_P;
//  if ((Pid_s & 0x1000) == 0) return SS_FALSE_P;

    //計器分類部を除外する。
    Pid_s = (Pid_s & 0x0FFF) + 1;

    PcsIdx_s = Sid_s - 1;

    //ＰＣＳ実装チェック 未実装の場合はエラー
    if (SS_ENTRY_P != JD_loc[PcsIdx_s].inf_us)	    return SS_FALSE_P;

    //回線種別がADA4000でない場合はエラー
    if (JD_NET_ADA_P != JD_loc[PcsIdx_s].netknd_us) return SS_FALSE_P;

    //ノード種別がVPCSの場合はエラー
    if ((JD_STN_VPCS_P == JD_loc[PcsIdx_s].nodes_us) ||
       (JD_STN_VPCS_2_P == JD_loc[PcsIdx_s].nodes_us)) return SS_FALSE_P;

    //ＰＣＳ種別がサポート外の場合はエラー(ADC4000,ADC5000,VC5000,VC100)
    if ((JD_loc[PcsIdx_s].tyopcs_us != JD_A4K_P	 ) &&
	(JD_loc[PcsIdx_s].tyopcs_us != JD_A5K_P	 ) &&
	(JD_loc[PcsIdx_s].tyopcs_us != JD_RC5_P)) return SS_FALSE_P;
	
	//最大物理ＩＤチック
	if (JD_loc[PcsIdx_s].skiki_us >= CNF_KEIKI_N) return SS_FALSE_P;
    
    //物理ＩＤ範囲チェック
    if ((1 > Pid_s) || ((JD_loc[PcsIdx_s].skiki_us + 1) < Pid_s)) return SS_FALSE_P;

    //下記の２つはやろうかとも思ったのですが、P-NET(Ethernet)側が
    //	やってないようなのではずしています。
	//監視グループ外
	//ＰＣＳロック

    *pSid_s = Sid_s;
    *pPid_s = Pid_s;

    return SS_TRUE_P;
}

//------------------------------------------------------------------------------
//マンマシンコマンドデータ受信時処理
//------------------------------------------------------------------------------
void f_11rv400(union U_ONE_BUF* pOneBuf)
{
    int			    Rsts_i;	    //リターンステータス
    int			    Size_i;     //サイズ

    D( DP1_("MO11RV マンマシンコマンドデータ受信\n"); )

    //受信データサイズ不正
    if ( (z_pOne->transfer.datalen < (S_HSZ+S_MSZ)) ||
         (z_pOne->transfer.datalen > (S_HSZ+S_MSZ+sizeof(z_cmdAns.text_s))) ) {
	    F_errlog( 0x1000, 0x4001, z_pOne->transfer.nodenum, z_pOne->transfer.datalen, 0, 0,
	              "受信データ数不正(INF1:Node,INF2:Size)");
	    return;
    }

    
    //要求元がPCSモニタでなければ
    if (pOneBuf->mhd.root_us[2] == 0xffff) return;

	memset( &z_cmdAns, 0, sizeof(struct Q_T_GPCSM_MAN) );
	memcpy( &z_cmdAns.mh
		, &pOneBuf->byte_uc[S_HSZ]
	, (z_pOne->transfer.datalen - S_HSZ) );
	memcpy( &z_cmdAns.qh.clntip_ul
		, &(pOneBuf->mhd.root_us[0])
		, sizeof(unsigned long));           //クライアントIP
	z_cmdAns.qh.winid_s = 
		pOneBuf->mhd.root_us[2];            //ウィンドウID
	z_cmdAns.qh.gkind_s = SS_DLLPCSMON_P;   //画面種別をPCSモニタ指定
	z_cmdAns.qkey_t     = Q_GSCRM_KEY1;     //送信先画面管理タスク
	z_cmdAns.qh.func_s = QF_GPCSM_MAN_P;    //マンマシンデータ応答

    Size_i = sizeof(struct Q_T_GPCSM_MAN);
    Rsts_i = F_quemgr( QUE_ENQ_P | QUE_NOWAIT_P, Q_GSCRM_KEY1,
		       &z_cmdAns, &Size_i );
    if (RS_SUC != Rsts_i) {
	    F_errlog( 0x0131, 0x4002, Rsts_i, 0, 0, 0,
	              "データ変更通知(マンマシンデータ応答)失敗(INF1:Stat)");
    }

}
