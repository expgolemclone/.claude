void f_errlog_ini(struct T_errfile_inf* file_inf)
{
    FILE*               fp;                         //̧���߲��
    char                fname_cp[64];               //�װ۸�̧�ٖ���
    char                buf_cp[2048];
    int                 cnt_i;                      //����
//  errno_t             err;                        //�߂�l

    for (cnt_i=0;cnt_i<=1;cnt_i++) {

        sprintf(fname_cp, "%s%d.log", file_inf->log_cp, cnt_i);
//      sprintf_s(fname_cp, (size_t)fname_cp, (const char *)"%s%d.log",
//                          file_inf->log_cp,
//                          cnt_i);
        fp = fopen(fname_cp, "r");                  //̧�ٵ����
//      err = fopen_s(&fp, fname_cp, "r");          //̧�ٵ����
        if (!fp) {                                  //̧�ٵ���ݎ��s
//      if (err!=0) {                               //̧�ٵ���ݎ��s
            continue;
        }
        file_inf->no_i=cnt_i;
        file_inf->rec_i=0;
        while (1) {
            fgets(buf_cp, sizeof(buf_cp), fp);      //̧�ق���1�s�ǂݍ���
            if (0 != feof(fp)) break;               //̧�ٴ��ނȂ��ٰ�߂𔲂���
            file_inf->rec_i++;
        }
        fclose(fp);
        if (file_inf->rec_i<Z_LOGFILE_MAXREC_N) {
            break;
        }
    }
    return;
}



