int  fl_gosav020(char *file_c, char *data_c, int size_i)
{
  int                      ret_i;               /*                            */
  HANDLE                   write_h;             /*                            */
  BOOL                     rsts_b;
  DWORD                    wsize_dw;


  ret_i   = RS_ERR;                             /* �߂�l�����s�ɂ���         */
  write_h = INVALID_HANDLE_VALUE;               /*                            */

  try {                                         /*                            */
                                                /*                            */
    do {                                        /*                            */

      write_h = fl_gosav010(                    /* �t�@�C�����I�[�v������     */
                    file_c, S_WRITE_P |         /*                            */
                    S_RND_P | S_OPEN_P);        /*                            */
      if (write_h == INVALID_HANDLE_VALUE){     /*                            */
          break;                                /*                            */
      }                                         /*                            */

      rsts_b = WriteFile(                       /*                            */
                   write_h, data_c, size_i,     /*                            */
                   &wsize_dw, NULL);            /*                            */

      if ((rsts_b != TRUE) ||                   /*                            */
          (wsize_dw != size_i)){                /*                            */
          F_errlog(0x151, 0xF0201,              /*                            */
                   GetLastError(),              /*                            */
                   rsts_b, wsize_dw, size_i,    /*                            */
                   "�t�@�C���̏������݂Ɏ��s"); /*                            */
          break;                                /*                            */
      }                                         /*                            */

      ret_i = RS_SUC;                           /* �߂�l�𐬌��ɂ���         */

    } while(0);                                 /*                            */
  }                                             /*                            */
  catch (...){                                  /*                            */
  }                                             /*                            */

  if (write_h != INVALID_HANDLE_VALUE){         /*                            */
    CloseHandle(write_h);                       /*                            */
  }                                             /*                            */

  return (ret_i);                               /*                            */
}                                               /*                            */


