 *  ��  �́F file_c    �t�@�C������
 *           mode_i    �I�[�v�����[�h
 *                       S_WRITE_P : ��������
 *                       S_READ_P  : �ǂݍ���
 *                       S_SEQ_P   : �V�[�P���V�����A�N�Z�X
 *                       S_RND_P   : �����_���A�N�Z�X
 *                       S_OPEN_P  : �t�@�C���ҏW
 *                       S_CRE_P   : �t�@�C���쐬
 *
 *  �o  �́F �Ȃ�
 *
 *  �߂�l�F �t�@�C���n���h��
 *
 *++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*/
HANDLE  fl_gosav010(char *file_c, int mode_i)
{
  HANDLE                   file_h;              /*                            */
  DWORD                    flag_dw;             /*                            */
  DWORD                    cre_dw;              /*                            */
  DWORD                    accs_dw;             /*                            */

  file_h = INVALID_HANDLE_VALUE;                /*                            */

  try {                                         /*                            */

    if ((mode_i & S_WRITE_P) != 0){             /* ��������                   */
      accs_dw = GENERIC_WRITE;                  /*                            */
      if ((mode_i & S_OPEN_P) != 0){            /*   �ҏW                     */
        cre_dw = OPEN_ALWAYS;                   /*                            */
      }                                         /*                            */
      else {                                    /*   �㏑��                   */
        cre_dw = CREATE_ALWAYS;                 /*                            */
      }                                         /*                            */
    }                                           /*                            */
    else {                                      /* �ǂݍ���                   */
      accs_dw = GENERIC_READ;                   /*                            */
      cre_dw  = OPEN_EXISTING;                  /*                            */
    }                                           /*                            */

    if ((mode_i & S_SEQ_P) != 0){               /* �V�[�P���V����             */
      flag_dw = FILE_FLAG_SEQUENTIAL_SCAN;      /*                            */
    }                                           /*                            */
    else {                                      /* �����_��                   */
      flag_dw = FILE_FLAG_RANDOM_ACCESS;        /*                            */
    }                                           /*                            */

    file_h = CreateFile(                        /*                            */
                 file_c, accs_dw,               /*                            */
                 FILE_SHARE_READ |              /*                            */
                 FILE_SHARE_WRITE,              /*                            */
                 NULL, cre_dw,                  /*                            */
                 FILE_ATTRIBUTE_NORMAL|flag_dw, /*                            */
                 NULL);                         /*                            */

    if (file_h == INVALID_HANDLE_VALUE){        /*                            */
      F_errlog(0x151, 0xF0101,                  /*                            */
               GetLastError(),                  /*                            */
               accs_dw, flag_dw, cre_dw,        /*                            */
               "�t�@�C���I�[�v���Ɏ��s");       /*                            */
    }                                           /*                            */
  }                                             /*                            */
  catch (...){                                  /*                            */
  }                                             /*                            */

  return (file_h);                              /*                            */
}                                               /*                            */

