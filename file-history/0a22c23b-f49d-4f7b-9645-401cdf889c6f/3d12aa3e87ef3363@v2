#Requires AutoHotkey v2.0
if !A_IsAdmin {
    ; 自分自身を「管理者として」再起動
    Run('*RunAs "' A_ScriptFullPath '"')
    ExitApp
}


; ==========================================
; AutoHotkey v2 設定
; ==========================================
; ==========================================
; メディアコントロール
; ==========================================
Ctrl & m::Media_Play_Pause
printscreen::Send("{Media_Prev}")
ScrollLock::Send("{Media_Play_Pause}")
F1 & c::Send("{Media_Prev}")
F1 & v::Send("{Media_Next}")
Pause::Send("{Media_Next}")
; ==========================================
; 音量コントロール
; ==========================================
PgUp::Volume_Up
PgDn::Volume_Down
F1 & g::Send("{Volume_Up}")
F1 & b::Send("{Volume_Down}")
; ==========================================
; 変換キー + 矢印キー（Vimライク）
; ==========================================
F1 & h:: {
    Send("{Blind}{Left}")
}
F1 & j:: {
    Send("{Blind}{Down}")
}
F1 & k:: {
    Send("{Blind}{Up}")
}
F1 & l:: {
    Send("{Blind}{Right}")
}
; ==========================================
; 変換キー + ナビゲーション
; ==========================================
; ctrl+F1+lのみ上手くいかないのはおそらくnote pcのハード的な問題
F1 & n::Home
F1 & m::End
F1 & f::Backspace
F1 & d::Del
F1 & s::Esc
F1 & a::F11
; ==========================================
; 変換キー + 数字
; ==========================================
F1 & q::1
F1 & w::2
F1 & e::3
F1 & r::4
F1 & t::5
F1 & y::6
F1 & u::7
F1 & i::8
F1 & o::9
F1 & p::0
F1 & @::-
F1 & [::^
; ==========================================
; その他のキーマッピング
; ==========================================
F1 & 2::F2
^Space::vk19
vkf0::Enter

^e::Send("!{F4}")
F6::\
F1::return        ; F1単体を無効化
F1 & x::Send ("AppsKey")

F1 & z:: {
    CoordMode("Mouse", "Screen")
    MouseMove(3840, 1080, 0)
}
;

; ==========================================
; ウインドウ切り替え
; ==========================================
^Enter:: {
    Send("!{Tab}")
}
#Enter:: {
    Send("!{Esc}")
}

