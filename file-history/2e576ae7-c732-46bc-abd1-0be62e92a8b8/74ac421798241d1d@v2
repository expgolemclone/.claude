#Requires AutoHotkey v2.0

; ============================================================
; espanso match/powershell-open.yml から移行
; PowerShell でフォルダを開くショートカット集
; ============================================================

#Hotstring *

; ============================================================
; ヘルパー関数
; ============================================================

OpenPowerShell(path) {
    Run("powershell.exe", path)
}

