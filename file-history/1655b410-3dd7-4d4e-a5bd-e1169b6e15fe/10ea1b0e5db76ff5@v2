#!/usr/bin/env python3
"""
Pattern C: strerror() → strerror_s() 一括置換スクリプト

対象パターン:
  sprintf(buf, "func(): %s", strerror(errno));
  →
  strerror_s(strerr_buf, sizeof(strerr_buf), errno);
  sprintf(buf, "func(): %s", strerr_buf);

使い方:
  python replace_strerror.py
  (プロジェクトルートから実行)
"""
import re
import os

# 対象ファイルリスト
files = [
    'src/NX_MW/opsnexus/uptrs.c',
    'src/NX_MW/opsnexus/mctrs.c',
    'src/NX_MW/opsnexus/main.c',
    'src/NX_MW/opsnexus/libetc.c',
    'src/NX_MW/opsnexus/init.c',
    'src/NX_MW/opsnexus/alive.c',
    'src/NX_MW/opsnexus/nexus_lib.c',
    'src/NX_MW/opsnexus/library.c',
    'src/NX_MW/opsnexus/deliv.c',
]

PROJECT_ROOT = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))


def process_file(filepath):
    """strerror() を strerror_s() に置換する"""
    fullpath = os.path.join(PROJECT_ROOT, filepath)
    raw = open(fullpath, 'rb').read()

    # エンコーディング検出 (cp932 → utf-8 → latin-1)
    for enc in ['cp932', 'utf-8', 'latin-1']:
        try:
            content = raw.decode(enc)
            break
        except UnicodeDecodeError:
            continue
    else:
        print(f'  SKIP (encoding): {filepath}')
        return

    original = content
    count = 0

    # --- 1. アクティブコード: sprintf内のstrerrorをインライン分離 ---
    # パターン: sprintf(buf, "...: %s", strerror(errno));
    # → strerror_s(strerr_buf, sizeof(strerr_buf), errno);\n<indent>sprintf(buf, "...: %s", strerr_buf);
    def replace_sprintf_strerror(m):
        nonlocal count
        count += 1
        indent = m.group(1)
        prefix = m.group(2)  # sprintf(buf, "...: %s",
        errno_arg = m.group(3)  # errno or errno variable
        suffix = m.group(4)  # );
        return (
            f'{indent}strerror_s(strerr_buf, sizeof(strerr_buf), {errno_arg});\n'
            f'{indent}{prefix}strerr_buf{suffix}'
        )

    content = re.sub(
        r'^(\s*)(sprintf\s*\([^,]+,\s*"[^"]*%s"\s*,\s*)strerror\s*\(\s*(\w+)\s*\)(\s*\)\s*;)',
        replace_sprintf_strerror,
        content,
        flags=re.MULTILINE
    )

    # --- 2. コメント内: strerror( → strerror_s( ---
    def replace_comment_strerror(m):
        nonlocal count
        count += 1
        return m.group(0).replace('strerror(', 'strerror_s(')

    # 行コメント //
    content = re.sub(
        r'//.*strerror\s*\(.*$',
        replace_comment_strerror,
        content,
        flags=re.MULTILINE
    )

    # ブロックコメント /* */
    content = re.sub(
        r'/\*.*?strerror\s*\(.*?\*/',
        replace_comment_strerror,
        content,
        flags=re.DOTALL
    )

    # --- 3. strerr_buf 宣言追加 ---
    # strerror_s が含まれる関数の先頭に char strerr_buf[256]; を追加
    if 'strerror_s(' in content and 'strerr_buf' in content:
        lines = content.split('\n')
        new_lines = []
        in_func = False
        brace_depth = 0
        decl_added = False

        for i, line in enumerate(lines):
            new_lines.append(line)
            stripped = line.strip()

            # 関数開始 ({のみの行)
            if stripped == '{' and brace_depth == 0:
                in_func = True
                brace_depth = 1
                decl_added = False
                continue

            if in_func:
                brace_depth += line.count('{') - line.count('}')

                # 宣言領域の終わり(空行)を検出して strerr_buf 宣言挿入
                if not decl_added and stripped == '' and brace_depth == 1:
                    # この関数内に strerror_s があるか先読み
                    func_text = '\n'.join(lines[i:])
                    next_close = func_text.find('\n}')
                    func_block = func_text[:next_close] if next_close > 0 else func_text
                    if 'strerror_s(' in func_block and 'char strerr_buf' not in '\n'.join(new_lines[-20:]):
                        indent_match = re.match(r'^(\s+)', lines[i - 1]) if i > 0 else None
                        indent = indent_match.group(1) if indent_match else '\t'
                        new_lines.insert(-1, f'{indent}char strerr_buf[256];')
                        decl_added = True

                if brace_depth <= 0:
                    in_func = False
                    brace_depth = 0

        content = '\n'.join(new_lines)

    if content != original:
        with open(fullpath, 'wb') as f:
            f.write(content.encode(enc))
        print(f'  {count} strerror replaced: {os.path.basename(filepath)}')
    else:
        print(f'  no changes: {os.path.basename(filepath)}')


if __name__ == '__main__':
    print('=== strerror → strerror_s replacement ===')
    total = 0
    for f in files:
        process_file(f)
    print('Done.')
