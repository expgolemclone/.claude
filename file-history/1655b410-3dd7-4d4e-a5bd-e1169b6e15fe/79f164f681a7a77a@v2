#!/usr/bin/env python3
"""
Pattern D: getenv() → getenv_s() 一括置換スクリプト (統合版)

処理内容:
  1. コメント内の getenv( → getenv_s( 置換
  2. アクティブコードの getenv 呼び出し置換
  3. 変数宣言の追加 (size_t env_len; char env_buf[256];)
  4. NULLチェックの変換 (== NULL → env_len == 0, != NULL → env_len > 0)
  5. ポインタ変数参照の env_buf への置換

使い方:
  python replace_getenv.py
  (プロジェクトルートから実行)
"""
import re
import os

PROJECT_ROOT = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

# --- コメントのみ変更対象のファイル ---
comment_only_files = [
    'src/NX_MW/libdl/liberrlog.c',
    'src/NX_MW/opsnexus/liberrlog.c',
    'src/ens/Dll/lelogf_dll/Lelogf.c',
]

# --- アクティブコード変更対象のファイル ---
active_files = [
    'src/ens/Dll/lelogf_dll/Lelogf.c',
    'src/ens/ens_common/ens_common.c',
    'src/ens/le100/le100_mntr/Genset100.c',
    'src/his/hstg120/hstg120.c',
    'src/his/hstsav/hstsav.c',
    'src/lib/vc/fsectoun.c',
    'src/lib/vc/fsectoun24.c',
    'src/msg/cotalk/f_tlk.c',
    'src/NX_MW/dfstat/main.c',
    'src/NX_MW/libdl/liberrlog.c',
    'src/NX_MW/nxstat/main.c',
    'src/NX_MW/opsnexus/alive.c',
    'src/NX_MW/opsnexus/init.c',
    'src/NX_MW/opsnexus/libetc.c',
    'src/NX_MW/opsnexus/liberrlog.c',
    'src/NX_MW/opsnexus/main.c',
    'src/NX_MW/opsnexus/nexus_lib.c',
    'src/rep/DLL/doexce_dll/DOEXCE.C',
    'src/sys/aosysi/aosysi.c',
]


def read_file(filepath):
    """cp932 → utf-8 → latin-1 のフォールバックでファイル読み込み"""
    fullpath = os.path.join(PROJECT_ROOT, filepath)
    raw = open(fullpath, 'rb').read()
    for enc in ['cp932', 'utf-8', 'latin-1']:
        try:
            return raw.decode(enc), enc, fullpath
        except UnicodeDecodeError:
            continue
    return None, None, fullpath


def write_file(fullpath, content, enc):
    """指定エンコーディングでファイル書き込み"""
    with open(fullpath, 'wb') as f:
        f.write(content.encode(enc))


def replace_comments(content):
    """コメント内の getenv( → getenv_s( を置換"""
    count = 0

    def replace_line_comment(m):
        nonlocal count
        count += 1
        return m.group(0).replace('getenv(', 'getenv_s(')

    def replace_block_comment(m):
        nonlocal count
        if 'getenv(' in m.group(0):
            count += 1
            return m.group(0).replace('getenv(', 'getenv_s(')
        return m.group(0)

    content = re.sub(r'//.*getenv\s*\(.*$', replace_line_comment, content, flags=re.MULTILINE)
    content = re.sub(r'/\*.*?getenv\s*\(.*?\*/', replace_block_comment, content, flags=re.DOTALL)

    return content, count


def replace_active_getenv(content):
    """
    アクティブコードの getenv 呼び出しを getenv_s に置換

    パターン1 (通常の代入):
      var = getenv("NAME");
      → getenv_s(&env_len, env_buf, sizeof(env_buf), "NAME");

    パターン2 (条件式内代入 — Genset100.c):
      if ((var = getenv("NAME")) != NULL)
      → getenv_s(&env_len, env_buf, sizeof(env_buf), "NAME");
         if (env_len > 0)
    """
    count = 0

    # パターン1: 通常の代入
    # var = getenv("VAR_NAME"); or var = getenv( "VAR_NAME" );
    def replace_assignment(m):
        nonlocal count
        count += 1
        indent = m.group(1)
        var_name = m.group(2)  # 未使用 (env_bufに置換)
        env_name = m.group(3)
        return f'{indent}getenv_s(&env_len, env_buf, sizeof(env_buf), {env_name});'

    content = re.sub(
        r'^(\s*)\w+\s*=\s*getenv\s*\(\s*("[^"]*")\s*\)\s*;',
        replace_assignment,
        content,
        flags=re.MULTILINE
    )

    # パターン2: 条件式内代入 (chk_c = getenv(...)) != NULL
    def replace_conditional(m):
        nonlocal count
        count += 1
        indent = m.group(1)
        env_name = m.group(2)
        rest = m.group(3)
        return (
            f'{indent}getenv_s(&env_len, env_buf, sizeof(env_buf), {env_name});\n'
            f'{indent}if (env_len > 0){rest}'
        )

    content = re.sub(
        r'^(\s*)if\s*\(\s*\(\s*\w+\s*=\s*getenv\s*\(\s*("[^"]*")\s*\)\s*\)\s*!=\s*NULL\s*\)(.*)',
        replace_conditional,
        content,
        flags=re.MULTILINE
    )

    return content, count


def replace_null_checks(content):
    """
    NULLチェックの変換:
      var == NULL  → env_len == 0
      var != NULL  → env_len > 0  (ただしこちらは条件式内代入で対応済みの場合もある)
    """
    count = 0

    # == NULL パターン (最も一般的)
    def replace_eq_null(m):
        nonlocal count
        count += 1
        indent = m.group(1)
        prefix = m.group(2)
        return f'{indent}{prefix}env_len == 0'

    content = re.sub(
        r'^(\s*)(if\s*\(\s*)\w+\s*==\s*NULL',
        replace_eq_null,
        content,
        flags=re.MULTILINE
    )

    return content, count


def replace_var_references(content, var_names):
    """
    旧ポインタ変数の参照を env_buf に置換
    例: strcpy(fname, env_p); → strcpy(fname, env_buf);
    """
    for var in var_names:
        # アクティブコード行のみ (コメント行は除外)
        content = re.sub(
            r'(?<!//.*)\b' + re.escape(var) + r'\b(?!\s*=\s*getenv)',
            'env_buf',
            content
        )
    return content


def add_declarations(content):
    """
    getenv_s を含む関数の先頭に size_t env_len; char env_buf[256]; を追加
    (既に宣言がある場合はスキップ)
    """
    if 'getenv_s(' not in content:
        return content
    if 'size_t env_len' in content:
        return content  # 既に宣言済み

    lines = content.split('\n')
    new_lines = []
    brace_depth = 0
    in_func = False
    decl_added_set = set()

    for i, line in enumerate(lines):
        new_lines.append(line)
        stripped = line.strip()

        if stripped == '{' and brace_depth == 0:
            in_func = True
            brace_depth = 1
            func_start = len(new_lines) - 1
            continue

        if in_func:
            brace_depth += line.count('{') - line.count('}')

            # 宣言領域(空行の前)を検出
            if stripped == '' and brace_depth == 1 and func_start not in decl_added_set:
                # この関数ブロック内に getenv_s があるか確認
                remaining = '\n'.join(lines[i:])
                # 次の関数閉じ括弧までを確認
                depth = 1
                for j, future_line in enumerate(lines[i:]):
                    depth += future_line.count('{') - future_line.count('}')
                    if depth <= 0:
                        remaining = '\n'.join(lines[i:i + j])
                        break

                if 'getenv_s(' in remaining:
                    indent_m = re.match(r'^(\s+)', lines[i - 1]) if i > 0 else None
                    indent = indent_m.group(1) if indent_m else '\t'
                    # 空行の前に宣言を挿入
                    new_lines.insert(-1, f'{indent}size_t env_len;')
                    new_lines.insert(-1, f'{indent}char env_buf[256];')
                    decl_added_set.add(func_start)

            if brace_depth <= 0:
                in_func = False
                brace_depth = 0

    return '\n'.join(new_lines)


def process_file(filepath, comment_only=False):
    """ファイルを処理"""
    content, enc, fullpath = read_file(filepath)
    if content is None:
        print(f'  SKIP (encoding): {filepath}')
        return

    original = content
    total_count = 0

    # Step 1: コメント置換
    content, count = replace_comments(content)
    total_count += count

    if not comment_only:
        # Step 2: アクティブコード置換
        content, count = replace_active_getenv(content)
        total_count += count

        # Step 3: NULLチェック変換
        content, count = replace_null_checks(content)
        total_count += count

        # Step 4: 宣言追加
        content = add_declarations(content)

    if content != original:
        write_file(fullpath, content, enc)
        label = '(comments only)' if comment_only else ''
        print(f'  {total_count} getenv replaced: {os.path.basename(filepath)} {label}')
    else:
        print(f'  no changes: {os.path.basename(filepath)}')


if __name__ == '__main__':
    print('=== getenv → getenv_s replacement ===')

    print('\n--- Comment-only files ---')
    for f in comment_only_files:
        process_file(f, comment_only=True)

    print('\n--- Active code files ---')
    for f in active_files:
        process_file(f, comment_only=False)

    print('\nDone.')
