        }
    }
    */
    //пњљ{пњљпњљ
    siz_i+=sprintf(&str_cp[siz_i],
                   " %s-%05d %s",
//                 &fn_cp[cnt_t+1],
                   fn_cp,
                   line_ui,
                   text_cp);
//  siz_i+=sprintf_s(&str_cp[siz_i],
//                   (size_t)str_cp,
//                   (const char *)" %s-%05d %s",
//                   fn_cp,
//                   line_ui,
