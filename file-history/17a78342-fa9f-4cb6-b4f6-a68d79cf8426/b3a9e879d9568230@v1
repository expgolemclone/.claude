//  fd_i=open(fname_cp, O_CREAT|O_RDWR, S_IRWXU|S_IRWXG|S_IRWXO);
    fd_h = (HANDLE)CreateFile(
           (LPCTSTR)fname_cp,
           (DWORD)GENERIC_WRITE | GENERIC_READ,
           (DWORD)FILE_SHARE_READ | FILE_SHARE_WRITE,
           (LPSECURITY_ATTRIBUTES)NULL,
           (DWORD)OPEN_ALWAYS,
           (DWORD)FILE_ATTRIBUTE_NORMAL | FILE_FLAG_RANDOM_ACCESS,
           (HANDLE)NULL) ;

//  if (fd_i==-1)
    if (fd_h==INVALID_HANDLE_VALUE)
    {
        return;
    }
//  lseek(fd_i, 0, SEEK_END);
    //пњљ|пњљCпњљпњљпњљ^пњљћИЏУпњљ
    Error_ui = (DWORD)SetFilePointer(
               (HANDLE)fd_h,
               (LONG)0,
               (PLONG)0,
               (DWORD)FILE_END) ;

//  write(fd_i, str_cp, strlen(str_cp));
    //пњљtпњљ@пњљCпњљпњљпњљ÷ВћПпњљпњљпњљпњљпњљпњљпњљ
    rtnsts_i = (INT)WriteFile(
               (HANDLE)fd_h,
