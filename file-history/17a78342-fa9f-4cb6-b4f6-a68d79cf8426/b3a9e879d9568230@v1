//++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
//  пњљ@  пњљ\пњљFпњљ„∞џЄпњљћІпњљўПпњљсПЙКпњљпњљпњљпњљпњљпњљпњљ
//  calling sequence:
//      void f_errlog_ini(struct T_errfile_inf*)
//  пњљпњљ  пњљЌБFпњљ»Впњљ
//  пњљo  пњљЌБFstruct T_errfile_inf*   //пњљ„∞џЄпњљћІпњљўПпњљпњљ
//  пњљяВпњљlпњљFпњљ»Впњљ
//  пњљTпњљ@пњљvпњљFпњљOпњљпњљIпњљпњљпњљпњљпњљћПпњљпњљпњљпњљжУЊпњљпњљпњљƒБAпњљ„∞џЄпњљћІпњљўПпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљпњљ
//++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
void f_errlog_ini(struct T_errfile_inf* file_inf)
{
    FILE*               fp;                         //ћІпњљпњљпњљя≤пњљпњљ
    char                fname_cp[64];               //пњљ„∞џЄпњљћІпњљўЦпњљпњљпњљ
    char                buf_cp[2048];
    int                 cnt_i;                      //пњљпњљпњљпњљ
//  errno_t             err;                        //пњљяВпњљl

    for (cnt_i=0;cnt_i<=1;cnt_i++) {

        sprintf(fname_cp, "%s%d.log", file_inf->log_cp, cnt_i);
//      sprintf_s(fname_cp, (size_t)fname_cp,
//                (const char *)"%s%d.log",
//                file_inf->log_cp,
//                cnt_i);
        fp = fopen(fname_cp, "r");                  //ћІпњљўµпњљпњљпњљпњљ
//      err = fopen_s(&fp, fname_cp, "r");          //ћІпњљўµпњљпњљпњљпњљ
        if (!fp) {                                  //ћІпњљўµпњљпњљпњљЁОпњљпњљs
//      if (err!=0) {                               //ћІпњљўµпњљпњљпњљЁОпњљпњљs
            continue;
        }
        file_inf->no_i=cnt_i;
        file_inf->rec_i=0;
        while (1) {
            fgets(buf_cp, sizeof(buf_cp), fp);      //ћІпњљўВпњљпњљпњљ1пњљsпњљ«ВЁНпњљпњљпњљ
            if (0 != feof(fp)) break;               //ћІпњљўіпњљпњљёВ»Впњљпњљў∞пњљяВрФ≤Впњљпњљпњљ
            file_inf->rec_i++;
        }
        fclose(fp);
        if (file_inf->rec_i<Z_LOGFILE_MAXREC_N) {
            break;
        }
    }
    return;
}



