//                 tm_p->tm_mon,
//                 tm_p->tm_mday,
//                 tm_p->tm_hour,
//                 tm_p->tm_min,
//                 tm_p->tm_sec,
//                 (int)tv.tv_usec);
                   tm_p.tm_year+1900,
                   tm_p.tm_mon,
                   tm_p.tm_mday,
                   tm_p.tm_hour,
                   tm_p.tm_min,
                   tm_p.tm_sec,
                   stm.wMilliseconds);
//  siz_i+=sprintf_s(&str_cp[siz_i],
//                   (size_t)str_cp,
//                   (const char *)"%04d/%02d/%02d %02d:%02d:%02d.%06d",
//                   tm_p->tm_year+1900,
//                   tm_p->tm_mon,
//                   tm_p->tm_mday,
//                   tm_p->tm_hour,
//                   tm_p->tm_min,
//                   tm_p->tm_sec,
//                   stm.wMilliseconds);
    /*
    //ћІпњљўЦпњљпњљћВпњљпњљпњљпњљяљпњљпњљпњљпњљпњљпњљпњљнПЬпњљпњљпњљпњљ
    for (cnt_t=strlen(fn_cp);cnt_t>=0;cnt_t--) {
        if (fn_cp[cnt_t]=='\\') {
