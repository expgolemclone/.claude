int leapyear( int year_i )
{
  return (0 == (year_i % 400)) || ((0 != (year_i % 100)) && (0 == (year_i %4)));
}

int daysinmonth( int year_i, int month_i )
{
  // �w�肳�ꂽ���̍ŏI����Ԃ�
  const int nDaysInMonth[] = { 31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31 };
  
  if ((month_i < 1) || (12 < month_i)) {
    return 0;
  }
  if ((2 == month_i) && leapyear(year_i)) {
    return 29;
  }
  return nDaysInMonth[month_i - 1];
}

int isgooddate( int year_i, int month_i, int day_i )
{
  int   rsts_i;    // ���^�[���R�[�h
  // �L���ȓ��t���`�F�b�N
  if ((month_i >= 1)&&(month_i <= 12)&&(day_i >= 1)&&
      (day_i <= daysinmonth(year_i, month_i))) {
    rsts_i = RS_SUC;
  } else {
    rsts_i = RS_ERR;
  }
  return rsts_i;
}

