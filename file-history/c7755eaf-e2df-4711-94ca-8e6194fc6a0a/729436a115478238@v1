int getfilesize(const char* fileName)
{
  fpos_t fsize = 0;
  
  FILE *fp = fopen(fileName,"rb");
  
  if (fp == NULL) {
    return 0;
  }

  // �t�@�C���T�C�Y�𒲍�
  fseek(fp,0,SEEK_END);
  fgetpos(fp,&fsize);

  fclose(fp);

  return (int)fsize;
}

