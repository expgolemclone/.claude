void fl_writelog(char *func_c, char *msg_c){
	size_t env_len;
	char env_buf[256];

  #define S_FILEMAX_N  10                     // �ő�t�@�C����
  #define S_LINEMAX_N  1000                   // �ő�s��

  int              cnt_i;
  int              fileno_i = 0;
  int              lineno_i = 0;
  char             file_c[128];
  char             *path_c = NULL;
  char             dir_c[128];
  char             log_c[256];
  HANDLE           find_h = NULL;
  WIN32_FIND_DATA  find_fd;
  FILETIME         find_ft;
  SYSTEMTIME       find_st;
  SYSTEMTIME       SysTim_st;                 // TH221020 ADD
  struct T_TIME    find_tt;                   // TH221020 MOD
  time_t           find_tm, new_tm;
  HANDLE           file_h;
  DWORD            create_dw, read_dw, write_dw;

  // ���ϐ����擾����
  getenv_s(&env_len, env_buf, sizeof(env_buf), "PATH_FILE");
  path_c = env_buf;
  if (env_len == 0){
    return;
  }

  // ���O�t�@�C���̊i�[��t�H���_�������ꍇ�͍쐬����
  for (cnt_i=0; cnt_i<=1; cnt_i++){
    if (cnt_i == 0){
      sprintf(dir_c, "%s\\log", path_c);
    }
    else {
      sprintf(dir_c, "%s\\log\\aoalm", path_c);
    }
    find_h = FindFirstFile(dir_c, &find_fd);
    if (find_h == INVALID_HANDLE_VALUE){
      CreateDirectory(dir_c, NULL);
    }
    else {
      FindClose(find_h);
    }
  }

  // �C���f�b�N�X�t�@�C������O�񏑂����񂾃t�@�C���ԍ��A�s�ԍ����擾����
  sprintf(file_c, "%s\\%s_00.txt", dir_c, func_c);
  file_h = CreateFile(
        file_c, GENERIC_READ, FILE_SHARE_READ, NULL, OPEN_EXISTING,
        FILE_ATTRIBUTE_NORMAL | FILE_FLAG_RANDOM_ACCESS, NULL);
  if (file_h != INVALID_HANDLE_VALUE){
    ReadFile(file_h, &fileno_i, sizeof(fileno_i), &read_dw, NULL);
    ReadFile(file_h, &lineno_i, sizeof(lineno_i), &read_dw, NULL);
    CloseHandle(file_h);
  }

  // �������ݍs�ԍ����P�i�߂�
  lineno_i++;
  if ((lineno_i >= 1) && (lineno_i <= S_LINEMAX_N) &&
      (fileno_i >= 1) && (fileno_i <= S_FILEMAX_N)){

    // �t�@�C���ԍ�����эs�ԍ����͈͓��̏ꍇ�͊����̃��O�t�@�C�����J��
    create_dw = OPEN_ALWAYS;
  }
  else {

    // �s�ԍ����͈͊O�̏ꍇ�͎��̃t�@�C���̐擪����n�߂�
    if ((lineno_i < 1) || (lineno_i > S_LINEMAX_N)){
      lineno_i = 1;
      fileno_i++;
    }

    // �Ō�̃t�@�C���܂ōs�����ꍇ�͐擪�̃t�@�C������n�߂�
    if (fileno_i > S_FILEMAX_N){
      lineno_i = 1;
      fileno_i = 1;
    }

    // �t�@�C���ԍ��������l�̏ꍇ�́A��ԐV�����t�@�C���𒲂ׂĎ�����n�߂�
    if (fileno_i < 1){

      lineno_i = 1;
      fileno_i = 1;
      new_tm   = 0;

      for (cnt_i=1; cnt_i<=S_FILEMAX_N; cnt_i++){

        // �t�@�C���̎������擾����
        sprintf(file_c, "%s\\%s_%02d.txt", dir_c, func_c, cnt_i);
        find_h = FindFirstFile(file_c, &find_fd);
        if (find_h != INVALID_HANDLE_VALUE){
          FindClose(find_h);
          FileTimeToLocalFileTime(&find_fd.ftLastWriteTime, &find_ft);
          FileTimeToSystemTime(&find_ft, &find_st);
          find_tt.ct_year_s = find_st.wYear;
          find_tt.ct_mon_s  = find_st.wMonth;
          find_tt.ct_day_s  = find_st.wDay;
          find_tt.ct_hour_s = find_st.wHour;
          find_tt.ct_min_s  = find_st.wMinute;
          find_tt.ct_sec_s  = find_st.wSecond;
          F_unittosec(&find_tt, &find_tm);

          // ��ԐV�����t�@�C���̎��̔ԍ����擾����
          if (find_tm >= new_tm){
            new_tm = find_tm;
            fileno_i = cnt_i + 1;
            if (fileno_i > S_FILEMAX_N){
              fileno_i = 1;
            }
          }
        }
      }
    }

    // �V�������O�t�@�C�����쐬����
    create_dw = CREATE_ALWAYS;
  }

  // ���b�Z�[�W�ɓ�����ǉ�����
//��TH221020 MOD �~���b�܂œo�^����悤�ɕύX
  GetLocalTime(&SysTim_st);
  sprintf(log_c, "%04d: %04d/%02d/%02d %02d:%02d:%02d.%03d  %s\r\n", lineno_i,
	  SysTim_st.wYear, SysTim_st.wMonth, SysTim_st.wDay,
	  SysTim_st.wHour, SysTim_st.wMinute, SysTim_st.wSecond, SysTim_st.wMilliseconds ,msg_c);
//��TH221020 MOD

  // ���O�t�@�C���̓ǂݎ�葮������������
  sprintf(file_c, "%s\\%s_%02d.txt", dir_c, func_c, fileno_i);
  find_h = FindFirstFile(file_c, &find_fd);
  if (find_h != INVALID_HANDLE_VALUE){
    FindClose(find_h);
    SetFileAttributes(file_c, FILE_ATTRIBUTE_NORMAL);
  }

  // ���O�t�@�C���ɏo�͂���
  file_h = CreateFile(
        file_c, GENERIC_WRITE | GENERIC_READ,
        FILE_SHARE_READ | FILE_SHARE_WRITE, NULL, create_dw,
        FILE_ATTRIBUTE_NORMAL | FILE_FLAG_RANDOM_ACCESS, NULL);
  if (file_h != INVALID_HANDLE_VALUE){
