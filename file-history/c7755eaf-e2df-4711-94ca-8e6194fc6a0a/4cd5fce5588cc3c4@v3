void fl_ntp024(UINT sec_ui,UINT msec_ui, time_t *sec_t,double *msec_d,int *msec_i)
{										//
  if (sec_ui){							//
    *sec_t = ntohl(sec_ui) - S_JAN1970;	//��M����������1970/01/01 ����̕b���ɕϊ�
    *sec_t += S_JST0900;				//���萢�E��(UTC)������{�W����(JST)�ɕϊ�
    }									//
  else {								//
    *sec_t = 0 ;						//
    }									//
  *msec_d = ntohl(msec_ui);				//�b���ȉ��̎������擾
  *msec_d /= 4294967296.0;				//
