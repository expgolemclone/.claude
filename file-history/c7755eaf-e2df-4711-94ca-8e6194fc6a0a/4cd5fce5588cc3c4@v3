  *layer_ui &= 0xff ;
  *pspan_ui = *cword_ui ;
  *pspan_ui >>= 8 ;
  *pspan_ui &= 0xff ;
  seido_ui = *cword_ui ;
  seido_ui &= 0xff ;
  *seido_c = (char)seido_ui ;
}

