void fl_ntp025(UINT sec_ui,double *res_d)
{										//
  UINT			temp_ui ;				//
  int			i ;						//
										//
  temp_ui = ntohl(sec_ui);				//�b���ȉ��̎������擾
  *res_d = 0.0 ;						//
  for (i=0 ; i<16 ; i++){				//
    if((temp_ui >> i) & 0x1) *res_d += pow(2,i-16) ;
