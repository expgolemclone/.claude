//++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
int f_init_node_comsts(struct node_comsts* node_comsts_p)
{
    SYSTEMTIME          stm ;           //GetLocalTime�p�����v�f
//	struct timeval		tv;				//����
//	struct timezone		tz;				//��ѿް�
                                        //���ʓ����e�[�u��
    static  int     z_dmsize[12] = {31, 28, 31, 30, 31, 30,
                                  31, 31, 30, 31, 30, 31} ;
    register        int     z_d0, z_d1, z_hms, z_day ;

	memset(node_comsts_p, 0, sizeof(struct node_comsts));
//	memset(&tv, 0, sizeof(struct timeval));
//	gettimeofday(&tv, &tz);
    GetLocalTime(&stm) ;
    if((stm.wYear % 4) == 0) {            /*�[�N���H                            */
        z_dmsize[1] = 29 ;                /*�Q�����Q�X���Ƃ���                  */
    } else {                              /*                                    */
        z_dmsize[1] = 28 ;                /*�Q�����Q�W���Ƃ���                  */
    }                                     /*                                    */
    if ((stm.wYear > 2099) ||             /*�N�A���A���A���A���A�b�̎w���      */ // OPS5000_64bit mod
        (stm.wYear < 1970) ||             /*�N�A���A���A���A���A�b�̎w���      */
        (stm.wMonth <  1) ||              /*�͈͂��z������̂���΁A            */
        (stm.wMonth > 12) ||              /*�p�����[�^�s���Ƃ���                */
        (stm.wHour <  0) ||
        (stm.wHour > 24) ||               /*24����̓��͂�������              */
        (stm.wMinute <  0) ||
        (stm.wMinute > 59) ||
        (stm.wSecond <  0) ||
        (stm.wSecond > 59) ||
        (stm.wDay < 1) ||
        (stm.wDay > z_dmsize[stm.wMonth - 1])){
    }
    else {
        z_hms = stm.wSecond + stm.wMinute*60
             + stm.wHour*3600L ;          /*�����̂O������̕b��                */
