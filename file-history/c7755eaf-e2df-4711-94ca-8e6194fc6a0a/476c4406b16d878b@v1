DllExport BOOL WINAPI dl_SubProcWait(void *addr_vp, int *code_ip, int tout_i)
{
	DWORD				dwWait;
	DWORD				dwExit;
	PROCESS_INFORMATION	*pi;

	if (tout_i == -1) {
		dwWait = INFINITE;
	}
	else {
		dwWait = tout_i;
	}
	pi = (PROCESS_INFORMATION *)addr_vp;

	if (WaitForSingleObject(pi->hProcess, dwWait) == WAIT_OBJECT_0) {
		GetExitCodeProcess(pi->hProcess, &dwExit);
		*code_ip = dwExit;
		CloseHandle(pi->hThread);
		CloseHandle(pi->hProcess);
		free(pi);
		return TRUE;
	}

	return FALSE;
}

